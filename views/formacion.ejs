<%- include('partials/head', {title: 'Formacion'}) %>

<header>
  <%- include('partials/navbar') %>
</header>
<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-4">
            <div class="card bg-dark border-secondary p-3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="text-white mb-0">Disposición Táctica</h5>
                    <div class="input-group style-select-tactica" style="width: auto;">
                        <span class="input-group-text bg-secondary text-white border-secondary">Esquema</span>
                        <select id="selector-formacion" class="form-select bg-dark text-white border-secondary">
                            <% Object.keys(formaciones).forEach(f => { %>
                                <option value="<%= f %>" <%= clubUsuario.tactica.formacion === f ? 'selected' : '' %>>
                                    <%= f %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div id="campo-futbol" class="pitch"></div>
                </div>
                <div class="card-footer d-flex justify-content-center gap-2">
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalRoles">
                        <i class="bi bi-person-badge"></i> Roles y Capitán
                    </button>
                    <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#modalCantera">
                        <i class="bi bi-mortarboard"></i> Cantera
                    </button>
                    <button class="btn btn-warning" onclick="guardarTodo()">
                        <i class="bi bi-save"></i> Guardar Todo
                    </button>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card bg-dark text-white border-secondary" style="max-height: 80vh; overflow-y: auto;">
                <div class="card-header bg-secondary">
                    <h5 class="mb-0 text-center">Gestión de Plantilla</h5>
                </div>
                
                <div class="p-2 bg-primary text-white small fw-bold">TITULARES</div>
                <ul id="lista-titulares" class="list-group list-group-flush sortable-list">
                    <% clubUsuario.plantilla.slice(0, 11).forEach((j, index) => { %>
                        <% const esCanterano = filial && filial.plantilla.some(p => p._id.toString() === j._id.toString()) %>
                        <li class="list-group-item bg-dark text-white border-secondary d-flex align-items-center" data-id="<%= j._id %>">
                            <span class="badge bg-secondary me-2"><%= index + 1 %></span>
                            <div class="flex-grow-1">
                                <strong><%= j.nombre %></strong> 
                                <strong><%= j.posicionPrincipal %></strong> 
                                <% if (esCanterano) { %><span class="badge bg-info text-dark" style="font-size: 0.6rem;">CANTERA</span><% } %>
                                <br><small class="text-muted"><%= j.posicion %></small>
                            </div>
                            </li>
                    <% }) %>
                </ul>

                <div class="p-2 bg-info text-dark small fw-bold">SUPLENTES</div>
                <ul id="lista-suplentes" class="list-group list-group-flush sortable-list">
                    <% clubUsuario.plantilla.slice(11, 24).forEach(j => { %>
                        <% const esCanterano = filial && filial.plantilla.some(p => p._id.toString() === j._id.toString()) %>
                        <li class="list-group-item bg-dark text-white border-secondary d-flex align-items-center" data-id="<%= j._id %>">
                            <div class="flex-grow-1">
                                <%= j.nombre %> 
                                <%= j.posicionPrincipal %>
                                <% if (esCanterano) { %><span class="badge bg-info text-dark ms-2" style="font-size: 0.6rem;">CANTERA</span><% } %>
                            </div>
                        </li>
                    <% }) %>
                </ul>

                <div class="p-2 bg-secondary text-white small fw-bold">RESERVAS</div>
                <ul id="lista-reservas" class="list-group list-group-flush sortable-list">
                    <% clubUsuario.plantilla.slice(24).forEach(j => { %>
                        <% const esCanterano = filial && filial.plantilla.some(p => p._id.toString() === j._id.toString()) %>
                        <li class="list-group-item bg-dark text-white border-secondary opacity-50 d-flex align-items-center" data-id="<%= j._id %>">
                            <div class="flex-grow-1">
                                <%= j.nombre %>
                                <%= j.posicionPrincipal %>
                                <% if (esCanterano) { %><span class="badge bg-info text-dark ms-2" style="font-size: 0.6rem;">CANTERA</span><% } %>
                            </div>
                        </li>
                    <% }) %>
                </ul>
            </div>
        </div>
    </div>
</div>

<%- include('partials/modal_formacion') %>
<%- include('partials/modal_subir_cantera') %>

<script src="/js/logicaFormaciones.js"></script>
<script>
    const FORMACIONES_DATA = JSON.parse('<%- JSON.stringify(formaciones) %>');
    const CLUB_ID = '<%= clubUsuario._id %>';

    document.addEventListener('DOMContentLoaded', () => {
        const formacionInicial = '<%= clubUsuario.tactica.formacion %>';

        if (typeof GestorTactico !== 'undefined') {
            GestorTactico.init(formacionInicial, FORMACIONES_DATA);
        }
    });

    function guardarTodo() {
        if (typeof GestorTactico !== 'undefined') {
            const formacionActual = document.getElementById('selector-formacion').value;
            GestorTactico.guardarCambios(CLUB_ID, formacionActual);
        }
    }
</script>