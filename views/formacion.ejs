<%- include('partials/head', {title: 'Formación'}) %>

<header>
    <%- include('partials/navbar') %>
</header>

<div class="container-fluid mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-4">
            <div class="card bg-dark border-secondary p-3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="text-white mb-0">Disposición Táctica</h5>
                    <div class="input-group style-select-tactica" style="width: auto;">
                        <span class="input-group-text bg-secondary text-white border-secondary">Esquema</span>
                        <select id="selector-formacion" class="form-select bg-dark text-white border-secondary" onchange="GestorTactico.cambiarEsquema(this.value)">
                            <% Object.keys(formaciones).forEach(f => { %>
                                <option value="<%= f %>" <%= clubUsuario.tactica.formacion === f ? 'selected' : '' %>>
                                    <%= f %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div id="campo-futbol" class="pitch">
                        <div class="mid-line"></div>
                        <div class="area-top"></div>
                        <div class="area-bottom"></div>
                        <div id="capa-jugadores"></div>
                    </div>
                </div>
                <div class="card-footer d-flex justify-content-center gap-2">
                    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalRoles">
                        <i class="bi bi-person-badge"></i> Roles
                    </button>
                    <button class="btn btn-info text-white" data-bs-toggle="modal" data-bs-target="#modalTacticas">
                        <i class="bi bi-sliders"></i> Tácticas
                    </button>
                    <button class="btn btn-success" data-bs-toggle="modal" data-bs-target="#modalCantera">
                        <i class="bi bi-mortarboard"></i> Cantera
                    </button>
                    <button class="btn btn-warning" onclick="guardarTodo()">
                        <i class="bi bi-save"></i> Guardar Alineación
                    </button>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card bg-dark text-white border-secondary" style="max-height: 85vh; overflow-y: auto;">
                <div class="card-header bg-secondary">
                    <h5 class="mb-0 text-center">Gestión de Plantilla</h5>
                </div>
                
                <div class="p-2 bg-primary text-white small fw-bold">TITULARES</div>
                <ul id="lista-titulares" class="list-group list-group-flush list-titulares-esquema">
                    <% 
                        const esquemaPosiciones = formaciones[clubUsuario.tactica.formacion].posiciones; 
                    %>
                    <% clubUsuario.plantilla.slice(0, 11).forEach((j, index) => { %>
                        <% const rolDelHueco = esquemaPosiciones[index]; %>
                        
                        <div class="d-flex align-items-center bg-dark border-bottom border-secondary px-2 fila-tactica-fija">
                            
                            <div class="col-auto text-center me-2 label-posicion-fija" data-index="<%= index %>">
                                <span class="badge bg-warning text-dark fw-bold badge-posicion-tactica" style="min-width: 48px; font-size: 0.8rem; display: inline-block;">
                                    <%= rolDelHueco %>
                                </span>
                            </div>
                            
                            <div class="flex-grow-1 style-jugador-container">
                                <%- include('partials/jugador_items', { j, esTitular: true, filial: filial, competicionActual: competicionActual }) %>
                            </div>
                            
                        </div>
                    <% }) %>
                </ul>

                <div class="p-2 bg-info text-dark small fw-bold">SUPLENTES</div>
                <ul id="lista-suplentes" class="list-group list-group-flush">
                    <% clubUsuario.plantilla.slice(11, 24).forEach(j => { %>
                        <%- include('partials/jugador_items', { j, esTitular: false, filial: filial, competicionActual: competicionActual }) %>
                    <% }) %>
                </ul>

                <div class="p-2 bg-secondary text-white small fw-bold">RESERVAS</div>
                <ul id="lista-reservas" class="list-group list-group-flush">
                    <% clubUsuario.plantilla.slice(24).forEach(j => { %>
                        <%- include('partials/jugador_items', { j, esTitular: false, filial: filial, competicionActual: competicionActual }) %>
                    <% }) %>
                </ul>
            </div>
        </div>
    </div>
</div>

<%- include('partials/modal_comparar_atributos') %>
<%- include('partials/modal_atributos') %>
<%- include('partials/modal_formacion') %>
<%- include('partials/modal_tacticas') %>
<%- include('partials/modal_subir_cantera') %>

<script src="/js/bootstrap.bundle.min.js"></script>
<script src="/js/ui.js"></script> 
<script src="/js/vistaAlertas.js"></script>
<script src="/js/logicaFormaciones.js"></script>

<script>
    const FORMACIONES_DATA = JSON.parse('<%- JSON.stringify(formaciones) %>');
    const CLUB_ID = '<%= clubUsuario._id %>';

    document.addEventListener('DOMContentLoaded', () => {
        // Inicializa el campo de fútbol visual
        GestorTactico.init('<%= clubUsuario.tactica.formacion %>', FORMACIONES_DATA);
        
        // CAPTURA DEL ERROR DE CONVOCATORIA DE JORNADA
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('errorConvocatoria') === 'true') {
            if (typeof UI !== 'undefined' && UI.notificarError) {
                UI.notificarError(
                    "Acción Cancelada", 
                    "No se ha podido disputar la jornada. Tienes futbolistas de baja médica o suspendidos dentro de tus 18 convocados (titulares o suplentes). Haz los cambios pertinentes antes de avanzar."
                );
                // Limpia la URL estéticamente para que no se quede el "?errorConvocatoria=true" al recargar
                window.history.replaceState({}, document.title, window.location.pathname);
            }
        }
    });

    // Función limpia para salvar la estrategia
    function guardarTodo() {
        if (typeof GestorTactico !== 'undefined') {
            GestorTactico.guardarCambios(CLUB_ID);
        }
    }
</script>