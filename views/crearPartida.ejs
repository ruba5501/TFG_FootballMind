<%- include('partials/head', {title: 'Crear partida'}) %>
<body>
  <div class="container mt-5">
    <h1 class="text-center mb-4">Crear Nueva Partida</h1>

    <form id="crearPartidaForm" action="/crearPartida" method="POST">
      
      <!-- PANTALLA 1: ENTRENADOR -->
      <div class="step" id="step1">
        <h4>Datos del Entrenador</h4>
        <div class="mb-3">
          <label>Nombre y Apellidos:</label>
          <input type="text" name="nombreEntrenador" class="form-control" required>
        </div>
        <div class="mb-3">
          <label>Edad:</label>
          <input type="number" name="edad" class="form-control" min="18" max="80" required>
        </div>
        <div class="mb-3">
          <label for="nacionalidad" class="form-label">Nacionalidad:</label>
          <select name="nacionalidad" id="nacionalidad" class="form-select" required>
            <option value="">Selecciona una nacionalidad</option>
            <option value="Alemania">Alemania</option>
            <option value="Argentina">Argentina</option>
            <option value="Australia">Australia</option>
            <option value="Bélgica">Bélgica</option>
            <option value="Brasil">Brasil</option>
            <option value="Canadá">Canadá</option>
            <option value="Chile">Chile</option>
            <option value="China">China</option>
            <option value="Colombia">Colombia</option>
            <option value="Corea del Sur">Corea del Sur</option>
            <option value="Croacia">Croacia</option>
            <option value="Dinamarca">Dinamarca</option>
            <option value="Egipto">Egipto</option>
            <option value="España">España</option>
            <option value="Estados Unidos">Estados Unidos</option>
            <option value="Francia">Francia</option>
            <option value="Inglaterra">Inglaterra</option>
            <option value="Italia">Italia</option>
            <option value="Japón">Japón</option>
            <option value="México">México</option>
            <option value="Marruecos">Marruecos</option>
            <option value="Nigeria">Nigeria</option>
            <option value="Noruega">Noruega</option>
            <option value="Países Bajos">Países Bajos</option>
            <option value="Paraguay">Paraguay</option>
            <option value="Perú">Perú</option>
            <option value="Polonia">Polonia</option>
            <option value="Portugal">Portugal</option>
            <option value="Suecia">Suecia</option>
            <option value="Uruguay">Uruguay</option>
          </select>
        </div>
        
        <h5>Atributos (450 puntos disponibles)</h5>
        <div id="puntosRestantes" class="text-danger mb-2">Puntos restantes: 450</div>

        <div class="row">
          <% const atributos = ['nivelFisico','nivelTecnico','nivelTactico','nivelPortero','nivelCantera','motivacion','desarrolloJovenes','reputacion','experiencia']; %>
          <% atributos.forEach(a => { %>
            <div class="col-md-4 mb-3">
              <label><%= a %></label>
              <input type="number" class="form-control atributo" name="atributos[<%= a %>]" min="0" max="100" value="0">
            </div>
          <% }) %>
        </div>

        <button type="button" class="btn btn-primary mt-3" id="next1">Siguiente</button>
      </div>

      <!-- PANTALLA 2: LIGA Y CLUB -->
      <div class="step d-none" id="step2">
        <h4>Selecciona tu Liga y Club</h4>
        <div class="mb-3">
          <label>Liga:</label>
          <select id="ligaSelect" class="form-select">
            <option value="">Selecciona una liga</option>
            <% ligas.forEach(l => { %>
              <option value="<%= l._id %>"><%= l.nombre %></option>
            <% }) %>
          </select>
        </div>

        <div class="mb-3">
          <label>Club:</label>
          <select id="club" name="clubSeleccionado" class="form-select" required>
            <option value="">Selecciona un club</option>
            <% clubes.forEach(c => { %>
              <option 
                data-ligas="<%= c.competiciones.map(co => co._id).join(',') %>" 
                value="<%= c._id %>">
                <%= c.nombre %>
              </option>
            <% }) %>
          </select>
        </div>

        <button type="button" class="btn btn-secondary" id="back2">Atrás</button>
        <button type="button" class="btn btn-primary" id="next2">Siguiente</button>
      </div>

      <!-- PANTALLA 3: GUARDAR -->
      <div class="step d-none" id="step3">
        <h4>Guardar Partida</h4>
        <div class="mb-3">
          <label>Nombre de la partida:</label>
          <input type="text" name="nombrePartida" class="form-control" required>
        </div>

        <button type="button" class="btn btn-secondary" id="back3">Atrás</button>
        <button type="submit" class="btn btn-success">Guardar Partida</button>
      </div>

    </form>
  </div>

  <script src="/js/crearPartida.js"></script>
</body>
</html>
