<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Crear Partida</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/crearPartida.css">
</head>
<body>
  <div class="container mt-5">
    <h1 class="text-center mb-4">Crear Nueva Partida</h1>

    <form id="crearPartidaForm" action="/crearPartida" method="POST">
      
      <!-- PANTALLA 1: ENTRENADOR -->
      <div class="step" id="step1">
        <h4>Datos del Entrenador</h4>
        <div class="mb-3">
          <label>Nombre y Apellidos:</label>
          <input type="text" name="nombreEntrenador" class="form-control" required>
        </div>
        <div class="mb-3">
          <label>Edad:</label>
          <input type="number" name="edad" class="form-control" min="18" max="80" required>
        </div>
        <div class="mb-3">
          <label>Nacionalidad:</label>
          <input type="text" name="nacionalidad" class="form-control" required>
        </div>

        <h5>Atributos (200 puntos disponibles)</h5>
        <div id="puntosRestantes" class="text-danger mb-2">Puntos restantes: 200</div>

        <div class="row">
          <% const atributos = ['nivelFisico','nivelTecnico','nivelTactico','nivelPortero','nivelCantera','motivacion','desarrolloJovenes','reputacion','experiencia']; %>
          <% atributos.forEach(a => { %>
            <div class="col-md-4 mb-3">
              <label><%= a %></label>
              <input type="number" class="form-control atributo" name="atributos[<%= a %>]" min="0" max="100" value="0">
            </div>
          <% }) %>
        </div>

        <button type="button" class="btn btn-primary mt-3" id="next1">Siguiente</button>
      </div>

      <!-- PANTALLA 2: LIGA Y CLUB -->
      <div class="step d-none" id="step2">
        <h4>Selecciona tu Liga y Club</h4>
        <div class="mb-3">
          <label>Liga:</label>
          <select id="ligaSelect" class="form-select">
            <option value="">Selecciona una liga</option>
            <% ligas.forEach(l => { %>
              <option value="<%= l._id %>"><%= l.nombre %></option>
            <% }) %>
          </select>
        </div>

        <div class="mb-3">
          <label>Club:</label>
          <select id="clubSelect" name="clubSeleccionado" class="form-select">
            <option value="">Selecciona un club</option>
            <% clubes.forEach(c => { %>
              <option data-liga="<%= c.liga._id %>" value="<%= c._id %>"><%= c.nombre %></option>
            <% }) %>
          </select>
        </div>

        <button type="button" class="btn btn-secondary" id="back2">Atrás</button>
        <button type="button" class="btn btn-primary" id="next2">Siguiente</button>
      </div>

      <!-- PANTALLA 3: GUARDAR -->
      <div class="step d-none" id="step3">
        <h4>Guardar Partida</h4>
        <div class="mb-3">
          <label>Nombre de la partida:</label>
          <input type="text" name="nombrePartida" class="form-control" required>
        </div>

        <button type="button" class="btn btn-secondary" id="back3">Atrás</button>
        <button type="submit" class="btn btn-success">Guardar Partida</button>
      </div>

    </form>
  </div>

  <script src="/js/crearPartida.js"></script>
</body>
</html>
