<% if (competicion.tipo && competicion.tipo.startsWith('internacional') && typeof tieneEliminatorias === 'undefined') { %>
    <div class="mb-3 d-flex align-items-center justify-content-between bg-dark border border-secondary p-2 rounded">
        <div class="small text-muted">
            <i class="bi bi-info-circle me-1 text-info"></i> Estás viendo las <strong>Eliminatorias</strong>
        </div>
        <% if (typeof partida !== 'undefined' && partida) { %>
            <a href="/clasificacion/<%= partida._id %>/<%= competicion._id %>" class="btn btn-sm btn-outline-info shadow-sm">
                <i class="bi bi-table me-1"></i> Ver Fase de Liga / Grupos
            </a>
        <% } %>
    </div>
<% } %>

<div class="accordion shadow-lg" id="acordeonCopa">
    <% 
        let rondasKeys = Object.keys(rondas).reverse(); 
        rondasKeys.forEach((nombreRonda, index) => { 
            let collapseId = "collapsePartial" + index; 
            let isExpanded = index === 0 ? "true" : "false"; 
            let showClass = index === 0 ? "show" : "";

            // LÓGICA DE EMPAREJAMIENTO ALINEADO
            let cruces = [];
            let mapaCruces = {}; // clave: idMenor_idMayor -> índice en el array 'cruces'
            let hayPartidosVuelta = false;

            rondas[nombreRonda].forEach(p => {
                const idLocal = p.equipoLocal._id.toString();
                const idVisitante = p.equipoVisitante._id.toString();
                
                const claveUnica = [idLocal, idVisitante].sort().join('_');

                if (typeof mapaCruces[claveUnica] === 'undefined') {
                    cruces.push({ ida: p, vuelta: null });
                    mapaCruces[claveUnica] = cruces.length - 1;
                } else {
                    cruces[mapaCruces[claveUnica]].vuelta = p;
                    hayPartidosVuelta = true;
                }
            });

            const formatearFechaPartido = (fechaRaw) => {
                if(!fechaRaw) return "Por definir";
                const diasSemana = ['Domingo', 'Lunes', 'Martes', 'Miércoles', 'Jueves', 'Viernes', 'Sábado'];
                const meses = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
                const d = new Date(fechaRaw);
                
                const diaSemana = diasSemana[d.getDay()];
                const diaMes = d.getDate();
                const mes = meses[d.getMonth()];
                const hora = d.getHours().toString().padStart(2, '0');
                const minutos = d.getMinutes().toString().padStart(2, '0');
                
                return `${diaSemana}, ${diaMes} ${mes} - ${hora}:${minutos}h`;
            };
    %>
        <div class="accordion-item border-secondary bg-dark text-white mb-2 rounded border">
            <h2 class="accordion-header" id="headingPartial<%= index %>">
                <button class="accordion-button <%= index !== 0 ? 'collapsed' : '' %> fw-bold bg-dark text-info border-bottom border-secondary border-opacity-25" 
                        type="button" 
                        data-bs-toggle="collapse" 
                        data-bs-target="#<%= collapseId %>" 
                        aria-expanded="<%= isExpanded %>">
                    <i class="bi bi-trophy-fill me-2 text-warning"></i> <%= nombreRonda %>
                </button>
            </h2>
            <div id="<%= collapseId %>" class="accordion-collapse collapse <%= showClass %>" data-bs-parent="#acordeonCopa">
                <div class="accordion-body bg-black bg-opacity-40 p-4">
                    
                    <% if (hayPartidosVuelta) { %>
                        <div class="row mb-3 d-none d-md-flex text-center">
                            <div class="col-6">
                                <h6 class="text-info small fw-bold text-uppercase tracking-wider mb-0">
                                    <i class="bi bi-play-circle-fill me-1"></i> Partidos de Ida
                                </h6>
                            </div>
                            <div class="col-6">
                                <h6 class="text-danger small fw-bold text-uppercase tracking-wider mb-0">
                                    <i class="bi bi-arrow-left-right me-1"></i> Partidos de Vuelta
                                </h6>
                            </div>
                        </div>
                    <% } else { %>
                        <h6 class="text-info small fw-bold text-uppercase tracking-wider mb-3">
                            <i class="bi bi-play-circle-fill me-1"></i> Eliminatoria a Partido Único
                        </h6>
                    <% } %>

                    <div class="d-flex flex-column gap-3">
                        <% cruces.forEach(cruce => { %>
                            <div class="row align-items-center g-3 border-bottom border-secondary border-opacity-10 pb-3 pb-md-0 border-0">
                                
                                <div class="col-md-<%= cruce.vuelta ? '6' : '12' %>">
                                    <% let p = cruce.ida; %>
                                    <% let esUsuario = clubUsuario && (p.equipoLocal._id.toString() === clubUsuario._id.toString() || p.equipoVisitante._id.toString() === clubUsuario._id.toString()); %>
                                    <% let bgClass = esUsuario ? 'border-primary border-2 shadow' : 'border-secondary border-opacity-50 bg-dark bg-opacity-70'; %>
                                    
                                    <div class="card h-100 bg-black bg-opacity-50 text-white shadow-sm <%= bgClass %>">
                                        <div class="card-header bg-transparent border-0 pt-2 pb-0 px-3">
                                            <small class="text-warning fw-bold text-uppercase font-monospace style-date">
                                                <i class="bi bi-clock me-1"></i><%= formatearFechaPartido(p.fecha) %>
                                            </small>
                                        </div>
                                        <div class="card-body p-3 pt-2">
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <div class="d-flex align-items-center overflow-hidden">
                                                    <img src="/img/escudos/<%= p.equipoLocal.escudo %>" width="22" height="22" class="me-2 flex-shrink-0">
                                                    <span class="text-truncate fw-semibold <%= p.jugado && (p.golesLocal > p.golesVisitante || p.ganadorPenaltis?.toString() === p.equipoLocal._id.toString()) ? 'text-white fw-bold' : 'text-white-50' %>">
                                                        <%= p.equipoLocal.nombre %>
                                                    </span>
                                                </div>
                                                <div class="d-flex align-items-center gap-1">
                                                    <% if (p.jugado && p.ganadorPenaltis) { %>
                                                        <span class="text-warning small me-1 font-monospace">(p. <%= p.marcadorTanda.golesLocal %>)</span>
                                                    <% } %>
                                                    <span class="badge <%= p.jugado ? 'bg-info text-dark fw-bold' : 'bg-secondary bg-opacity-25 text-muted' %> fs-6 px-2.5">
                                                        <%= p.jugado ? p.golesLocal : '-' %>
                                                    </span>
                                                </div>
                                            </div>
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div class="d-flex align-items-center overflow-hidden">
                                                    <img src="/img/escudos/<%= p.equipoVisitante.escudo %>" width="22" height="22" class="me-2 flex-shrink-0">
                                                    <span class="text-truncate fw-semibold <%= p.jugado && (p.golesVisitante > p.golesLocal || p.ganadorPenaltis?.toString() === p.equipoVisitante._id.toString()) ? 'text-white fw-bold' : 'text-white-50' %>">
                                                        <%= p.equipoVisitante.nombre %>
                                                    </span>
                                                </div>
                                                <div class="d-flex align-items-center gap-1">
                                                    <% if (p.jugado && p.ganadorPenaltis) { %>
                                                        <span class="text-warning small me-1 font-monospace">(p. <%= p.marcadorTanda.golesVisitante %>)</span>
                                                    <% } %>
                                                    <span class="badge <%= p.jugado ? 'bg-info text-dark fw-bold' : 'bg-secondary bg-opacity-25 text-muted' %> fs-6 px-2.5">
                                                        <%= p.jugado ? p.golesVisitante : '-' %>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <% if (cruce.vuelta) { %>
                                    <div class="col-md-6">
                                        <% let pv = cruce.vuelta; %>
                                        <% let esUsuarioV = clubUsuario && (pv.equipoLocal._id.toString() === clubUsuario._id.toString() || pv.equipoVisitante._id.toString() === clubUsuario._id.toString()); %>
                                        <% let bgClassV = esUsuarioV ? 'border-primary border-2 shadow' : 'border-secondary border-opacity-50 bg-dark bg-opacity-70'; %>
                                        
                                        <div class="card h-100 bg-black bg-opacity-50 text-white shadow-sm <%= bgClassV %>">
                                            <div class="card-header bg-transparent border-0 pt-2 pb-0 px-3">
                                                <small class="text-warning fw-bold text-uppercase font-monospace style-date">
                                                    <i class="bi bi-clock me-1"></i><%= formatearFechaPartido(pv.fecha) %>
                                                </small>
                                            </div>
                                            <div class="card-body p-3 pt-2">
                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <div class="d-flex align-items-center overflow-hidden">
                                                        <img src="/img/escudos/<%= pv.equipoLocal.escudo %>" width="22" height="22" class="me-2 flex-shrink-0">
                                                        <span class="text-truncate fw-semibold <%= pv.jugado && (pv.golesLocal > pv.golesVisitante || pv.ganadorPenaltis?.toString() === pv.equipoLocal._id.toString()) ? 'text-white fw-bold' : 'text-white-50' %>">
                                                            <%= pv.equipoLocal.nombre %>
                                                        </span>
                                                    </div>
                                                    <div class="d-flex align-items-center gap-1">
                                                        <% if (pv.jugado && pv.ganadorPenaltis) { %>
                                                            <span class="text-warning small me-1 font-monospace">(p. <%= pv.marcadorTanda.golesLocal %>)</span>
                                                        <% } %>
                                                        <span class="badge <%= pv.jugado ? 'bg-info text-dark fw-bold' : 'bg-secondary bg-opacity-25 text-muted' %> fs-6 px-2.5">
                                                            <%= pv.jugado ? pv.golesLocal : '-' %>
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <div class="d-flex align-items-center overflow-hidden">
                                                        <img src="/img/escudos/<%= pv.equipoVisitante.escudo %>" width="22" height="22" class="me-2 flex-shrink-0">
                                                        <span class="text-truncate fw-semibold <%= pv.jugado && (pv.golesVisitante > pv.golesLocal || pv.ganadorPenaltis?.toString() === pv.equipoVisitante._id.toString()) ? 'text-white fw-bold' : 'text-white-50' %>">
                                                            <%= pv.equipoVisitante.nombre %>
                                                        </span>
                                                    </div>
                                                    <div class="d-flex align-items-center gap-1">
                                                        <% if (pv.jugado && pv.ganadorPenaltis) { %>
                                                            <span class="text-warning small me-1 font-monospace">(p. <%= pv.marcadorTanda.golesVisitante %>)</span>
                                                        <% } %>
                                                        <span class="badge <%= pv.jugado ? 'bg-info text-dark fw-bold' : 'bg-secondary bg-opacity-25 text-muted' %> fs-6 px-2.5">
                                                            <%= pv.jugado ? pv.golesVisitante : '-' %>
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                <% } %>

                            </div>
                        <% }) %>
                    </div>

                </div>
            </div>
        </div>
    <% }) %>
</div>

<style>
    .tracking-wider { letter-spacing: 0.05rem; }
    .style-date { font-size: 0.75rem; }
    .accordion-button::after { filter: invert(1); }
</style>