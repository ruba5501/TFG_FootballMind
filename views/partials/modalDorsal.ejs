<div class="modal fade" id="modalDorsal" tabindex="-1">
    <div class="modal-dialog modal-md"> <div class="modal-content bg-dark text-white border-info">
            <div class="modal-header border-secondary">
                <h5 class="modal-title"><i class="bi bi-hash me-2"></i>Asignar Dorsal</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-4">
                <p class="text-muted small mb-4">Selecciona un número del 1 al 99</p>
                
                <div class="d-flex justify-content-center align-items-center gap-3 mb-4">
                    <input type="number" id="inputDorsal" 
                           class="form-control form-control-lg text-center fw-bold" 
                           style="width: 100px; font-size: 2rem; border-color: #0dcaf0;" 
                           min="1" max="99" value="1">
                </div>

                <div id="infoOcupante" class="alert alert-info d-none py-2 px-3 mx-auto" style="max-width: 300px;">
                    </div>

                <div id="infoLibre" class="text-success small mb-3">
                    <i class="bi bi-check-circle-fill"></i> Dorsal disponible
                </div>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-info px-4" id="btnConfirmarDorsal">Confirmar Cambio</button>
            </div>
        </div>
    </div>
</div>