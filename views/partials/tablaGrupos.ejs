<% if (competicion.faseActual === 'eliminatorias') { %>
    <div class="alert alert-info d-flex justify-content-between align-items-center shadow-sm border-0 mb-4">
        <div>
            <i class="bi bi-info-circle-fill me-2"></i>
            <strong>Fase de grupos finalizada.</strong> Ya puedes consultar los cruces.
        </div>
        <button onclick="typeof cargarInfo === 'function' ? cargarInfo('<%= competicion._id %>', 'copa') : window.location.href='/copa/<%= competicion.partidaId %>/<%= competicion._id %>'" 
                class="btn btn-primary btn-sm shadow-sm">
            <i class="bi bi-diagram-3 me-2"></i>Ver Eliminatorias
        </button>
    </div>
<% } %>
<div class="row g-4">
    <% Object.keys(grupos).sort().forEach(nombreGrupo => { %>
        <div class="col-xl-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white fw-bold">
                    <%= nombreGrupo %>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead class="bg-light">
                            <tr class="text-center" style="font-size: 0.85rem;">
                                <th>Pos</th>
                                <th class="text-start">Club</th>
                                <th>PTS</th>
                                <th>PJ</th>
                                <th>DIF</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% grupos[nombreGrupo].forEach((fila, index) => { 
                                let esUsuario = clubUsuario && fila.club._id.toString() === clubUsuario._id.toString();
                            %>
                                <tr class="text-center <%= esUsuario ? 'table-primary' : '' %>" style="font-size: 0.9rem;">
                                    <td class="fw-bold"><%= index + 1 %></td>
                                    <td class="text-start">
                                        <img src="/img/escudos/<%= fila.club.escudo %>" width="20" class="me-1">
                                        <span class="text-truncate" style="max-width: 120px; display: inline-block; vertical-align: bottom;">
                                            <%= fila.club.nombre %>
                                        </span>
                                    </td>
                                    <td class="fw-bold"><%= fila.pts %></td>
                                    <td><%= fila.pj %></td>
                                    <td class="<%= (fila.gf - fila.gc) > 0 ? 'text-success' : 'text-danger' %>">
                                        <%= (fila.gf - fila.gc) > 0 ? '+' + (fila.gf - fila.gc) : (fila.gf - fila.gc) %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    <% }) %>
</div>