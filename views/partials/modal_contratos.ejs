<div class="modal fade" id="modalContrato" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="tituloModalContrato">Negociación de Contrato</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body bg-light">
                <div class="row align-items-center mb-4">
                    <div class="col-auto">
                        <div class="display-4">👤</div>
                    </div>
                    <div class="col">
                        <h4 id="contNombre" class="mb-0">Nombre del Sujeto</h4>
                        <p id="contTipo" class="text-muted mb-0">Jugador</p>
                        <div class="d-flex gap-2 mt-2 d-none" id="isJugador">
                            <span class="badge bg-primary" id="Media">Media: --</span>
                            <span class="badge bg-info" id="Potencial">Pot: --</span>
                        </div>
                    </div>
                    <div class="col-auto text-end">
                        <small class="text-muted d-block">Sueldo Actual</small>
                        <strong id="contSueldoActual">0 €</strong>
                        <div id="finContrato" class="d-none">
                            <hr class="my-1">
                            <small class="text-muted d-block">Fin de contrato: </small>
                            <small id="contFinContrato" class="fw-bold text-danger"></small>
                        </div>
                    </div>
                </div>
                <div id="interesJugador" class="d-none mb-3">
                    <div class="card shadow-sm">
                        <div class="card-body">
                            <label class="small text-uppercase fw-bold text-muted">Interés en unirse</label>
                            <div class="progress mt-1" style="height: 10px;">
                                <div id="barraInteresContrato" class="progress-bar bg-success" style="width: 0%"></div>
                            </div>
                            <small id="textoInteresContrato" class="text-muted text-center d-block mt-1">Calculando...</small>
                        </div>
                    </div>
                </div>

                <form id="formContrato">
                    <div class="card border-0 shadow-sm p-4">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label for="ofertaSueldo" class="form-label fw-bold">Sueldo ofrecido (€)</label>
                                <input type="number" class="form-control form-control-lg shadow-sm" id="ofertaSueldo" placeholder="Ej: 500000" min="0">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Duración (Años)</label>
                                <select id="ofertaAnios" class="form-select form-select-lg">
                                    <option value="1">1 Año</option>
                                    <option value="2">2 Años</option>
                                    <option value="3">3 Años</option>
                                    <option value="4">4 Años</option>
                                    <option value="5">5 Años</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Rol Prometido</label>
                                <select id="ofertaRol" class="form-select">
                                    </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Cláusula de Rescisión (€)</label>
                                <input type="number" id="ofertaClausula" class="form-control" placeholder="Opcional">
                            </div>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button type="button" onclick="confirmarContrato()" class="btn btn-primary btn-lg">Enviar Contrato</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>