<% 
    let esCanteranoVal = false;
    if (typeof filial !== 'undefined' && filial && filial.plantilla) {
        esCanteranoVal = filial.plantilla.some(p => p._id.toString() === j._id.toString());
    }

    const formaVal = j.estadoFisico || 100;
    
    let colorClase = 'bg-fitness-low';
    if (formaVal > 80) {
        colorClase = 'bg-fitness-high';
    } else if (formaVal > 50) {
        colorClase = 'bg-fitness-mid';
    }
    
    const valorForma = formaVal; 
%>

<li class="list-group-item bg-dark text-white border-secondary d-flex align-items-center jugador-item <%= esTitular ? 'fw-bold' : '' %>" 
    data-id="<%= j._id %>" 
    data-posicion="<%= j.posicionPrincipal %>"
    data-secundarias="<%= (j.posicionesSecundarias || []).join(',') %>"
    onclick="GestorTactico.seleccionarJugador(this)">
    
    <div class="flex-grow-1">
        <div class="d-flex justify-content-between">
            <strong class="nombre-txt"><%= j.nombre %></strong>
            <span class="badge bg-light text-dark small"><%= j.posicionPrincipal %></span>
        </div>
        
        <div class="d-flex align-items-center gap-2">
            <div class="fitness-container" style="width: 60px; height: 8px; background: #444; border-radius: 4px; overflow: hidden;">
                <div class="fitness-bar <%= colorClase %>" 
                     style="--p: <%= valorForma %>; width: calc(var(--p) * 1%); height: 100%;">
                </div>
            </div>
            
            <small class="text-muted" style="font-size: 0.7rem;"><%= formaVal %>%</small>
            
            <% if (esCanteranoVal) { %>
                <span class="badge bg-info text-dark" style="font-size: 0.5rem;">CANTERA</span>
            <% } %>
        </div>
    </div>

    <button type="button" class="btn btn-sm btn-outline-info ms-2" onclick="event.stopPropagation(); verAtributos('<%= j._id %>')">
        <i class="bi bi-bar-chart-fill"></i>
    </button>
</li>