<div class="col-md-3">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-dark text-white fw-bold">
            <i class="bi bi-info-circle me-2"></i>Próximo Partido
        </div>
        <div class="card-body text-center">
            <% 
                const proximo = partidos.sort((a,b) => a.fecha - b.fecha).find(p => p.jugado === false);
                
                if (proximo) { 
                    const esLocal = proximo.equipoLocal._id.toString() === clubUsuario._id.toString();
                    const rival = esLocal ? proximo.equipoVisitante : proximo.equipoLocal;
            %>
                <div class="mb-2">
                    <span class="badge bg-primary"><%= proximo.competicionId.nombre %></span>
                </div>
                
                <div class="d-flex justify-content-between align-items-center my-3">
                    <div class="text-center">
                        <img src="/img/escudos/<%= clubUsuario.nombre.toLowerCase().replace(/ /g, '_') %>.png" width="45" onerror="this.src='/img/escudos/default.png'">
                        <div class="small fw-bold mt-1">Tú</div>
                    </div>
                    <div class="fw-bold h4">VS</div>
                    <div class="text-center">
                        <img src="/img/escudos/<%= rival.nombre.toLowerCase().replace(/ /g, '_') %>.png" width="45" onerror="this.src='/img/escudos/default.png'">
                        <div class="small fw-bold mt-1 text-truncate" style="max-width: 70px;"><%= rival.nombre %></div>
                    </div>
                </div>

                <hr>
                
                <div class="text-start small">
                    <p class="mb-1"><i class="bi bi-calendar-event me-2"></i><%= proximo.fecha.toLocaleDateString('es-ES', { day: 'numeric', month: 'long' }) %></p>
                    <p class="mb-1"><i class="bi bi-geo-alt me-2"></i><%= esLocal ? 'Tu Estadio' : 'Visitante' %></p>
                </div>

                <% if (proximo.fecha.toDateString() === partida.fechaActual.toDateString()) { %>
                    <a href="/jugar/<%= proximo._id %>" class="btn btn-success w-100 mt-3 fw-bold animate__animated animate__pulse animate__infinite">
                        <i class="bi bi-play-fill me-1"></i> JUGAR AHORA
                    </a>
                <% } else { %>
                    <button class="btn btn-secondary w-100 mt-3" disabled>Esperar fecha</button>
                <% } %>

            <% } else { %>
                <p class="text-muted my-4">No hay partidos programados para este mes.</p>
                <i class="bi bi-emoji-smile h1 text-muted"></i>
            <% } %>
        </div>
    </div>
</div>