<% 
    // Buscamos el primer partido no jugado
    let prox = partidos.find(p => !p.jugado);
    
    if (prox) { 
        let local = prox.equipoLocal;
        let visitante = prox.equipoVisitante;
        let esLocalUsuario = local._id.toString() === clubUsuario._id.toString();
%>
    <div class="d-flex flex-column align-items-center justify-content-center w-100 text-center py-2">
        
        <span class="badge bg-secondary mb-4 px-3 py-2 text-uppercase shadow-sm">
            <%= prox.competicionId && prox.competicionId.tipo === 'LIGA' ? 'Liga - Jornada ' + prox.jornada : 'Competición' %>
        </span>
        
        <div class="d-flex justify-content-between align-items-center w-100 px-2 my-2">
            
            <div class="d-flex flex-column align-items-center" style="flex-basis: 40%;">
                <img src="/img/escudos/<%= local.escudo %>" alt="<%= local.nombre %>" width="80" class="mb-2 drop-shadow">
                <span class="fw-bold fs-6 <%= esLocalUsuario ? 'text-primary' : 'text-dark' %>">
                    <%= local.nombre %>
                </span>
            </div>

            <div class="d-flex flex-column align-items-center justify-content-center" style="flex-basis: 20%;">
                <span class="fw-black fs-4 text-muted opacity-75">VS</span>
            </div>

            <div class="d-flex flex-column align-items-center" style="flex-basis: 40%;">
                <img src="/img/escudos/<%= visitante.escudo %>" alt="<%= visitante.nombre %>" width="80" class="mb-2 drop-shadow">
                <span class="fw-bold fs-6 <%= !esLocalUsuario ? 'text-primary' : 'text-dark' %>">
                    <%= visitante.nombre %>
                </span>
            </div>

        </div>

        <div class="mt-4 text-muted small fw-semibold text-capitalize">
            <i class="bi bi-calendar-event me-1"></i> 
            <%= new Date(prox.fecha).toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
        </div>
    </div>
<% } else { %>
    <div class="text-center text-muted py-5 w-100">
        <i class="bi bi-calendar-x fs-1 opacity-50 mb-2"></i>
        <p class="mb-0 fw-bold">No hay partidos programados.</p>
    </div>
<% } %>