<div class="card shadow-sm border-0">
    <div class="card-header bg-dark text-white fw-bold text-center py-1" style="font-size: 0.75rem;">
        PRÓXIMO PARTIDO
    </div>
    <div class="card-body p-2">
        <% 
            if (proximoPartido) { 
                const loc = proximoPartido.equipoLocal;
                const vis = proximoPartido.equipoVisitante;
        %>
            <div class="text-center mb-2">
                <div class="badge bg-primary text-truncate w-100" style="font-size: 0.6rem; display: block;">
                    <%= proximoPartido.competicionId.nombre %>
                </div>
            </div>

            <div class="d-flex align-items-center justify-content-center flex-nowrap mb-1">
                <div class="text-center">
                    <img src="/img/escudos/<%= loc.escudo %>" width="35" height="35" title="<%= loc.nombre %>" style="object-fit: contain;">
                </div>
                
                <div class="px-3 fw-bolder text-dark" style="font-size: 0.9rem; flex-shrink: 0;">VS</div>

                <div class="text-center">
                    <img src="/img/escudos/<%= vis.escudo %>" width="35" height="35" title="<%= vis.nombre %>" style="object-fit: contain;">
                </div>
            </div>

            <div class="text-center mb-2" style="line-height: 1.1;">
                <div class="fw-bold text-truncate" style="font-size: 0.65rem;"><%= loc.nombre %></div>
                <div class="text-muted" style="font-size: 0.6rem;">vs</div>
                <div class="fw-bold text-truncate" style="font-size: 0.65rem;"><%= vis.nombre %></div>
            </div>

            <div class="text-center border-top pt-2 mt-1" style="font-size: 0.7rem;">
                <span class="text-dark fw-bold">
                    <%= proximoPartido.fecha.getDate() %>/<%= proximoPartido.fecha.getMonth()+1 %>
                </span>
                <span class="mx-1 text-muted">|</span>
                <span class="text-primary fw-bold">
                    <%= proximoPartido.fecha.toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' }) %>
                </span>
            </div>

            <% if (proximoPartido.fecha.toDateString() === partida.fechaActual.toDateString()) { %>
                <a href="/jugar/<%= proximoPartido._id %>" class="btn btn-success btn-sm w-100 mt-2 fw-bold" style="font-size: 0.7rem;">
                    JUGAR AHORA
                </a>
            <% } %>

        <% } else { %>
            <div class="text-center py-2 text-muted" style="font-size: 0.7rem;">No hay partidos</div>
        <% } %>
    </div>
</div>