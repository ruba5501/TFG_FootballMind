<% 
    let prox = typeof proximoPartido !== 'undefined' && proximoPartido ? proximoPartido : (typeof partidos !== 'undefined' ? partidos.find(p => !p.jugado) : null);
    
    if (prox) { 
        let local = prox.equipoLocal;
        let visitante = prox.equipoVisitante;
        let esLocalUsuario = typeof clubUsuario !== 'undefined' ? local._id.toString() === clubUsuario._id.toString() : false;
%>
    <div class="card shadow-sm border-0 w-100">
        <div class="card-header bg-dark text-white fw-bold text-center py-2">
            PRÓXIMO PARTIDO
        </div>
        
        <div class="card-body d-flex flex-column align-items-center justify-content-center py-3">
            
            <span class="badge bg-primary mb-4 px-3 py-2 text-uppercase shadow-sm">
                <%= prox.competicionId && prox.competicionId.tipo === 'LIGA' ? 'Liga - Jornada ' + prox.jornada : (prox.competicionId ? prox.competicionId.nombre : 'Competición') %>
            </span>
            
            <div class="d-flex justify-content-between align-items-center w-100 px-2 my-2">
                
                <div class="d-flex flex-column align-items-center text-center" style="flex-basis: 40%;">
                    <img src="/img/escudos/<%= local.escudo %>" alt="<%= local.nombre %>" width="80" class="mb-2 drop-shadow" style="object-fit: contain;">
                    <span class="fw-bold fs-6 <%= esLocalUsuario ? 'text-primary' : 'text-dark' %> text-truncate w-100" title="<%= local.nombre %>">
                        <%= local.nombre %>
                    </span>
                </div>

                <div class="d-flex flex-column align-items-center justify-content-center" style="flex-basis: 20%;">
                    <span class="fw-black fs-4 text-muted opacity-75">VS</span>
                </div>

                <div class="d-flex flex-column align-items-center text-center" style="flex-basis: 40%;">
                    <img src="/img/escudos/<%= visitante.escudo %>" alt="<%= visitante.nombre %>" width="80" class="mb-2 drop-shadow" style="object-fit: contain;">
                    <span class="fw-bold fs-6 <%= !esLocalUsuario ? 'text-primary' : 'text-dark' %> text-truncate w-100" title="<%= visitante.nombre %>">
                        <%= visitante.nombre %>
                    </span>
                </div>
            </div>

            <div class="mt-4 text-center" style="line-height: 1.4;">
                <div class="text-muted small fw-semibold text-capitalize">
                    <i class="bi bi-calendar-event me-1"></i> 
                    <%= new Date(prox.fecha).toLocaleDateString('es-ES', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
                </div>
                <div class="text-primary fw-bold mt-1">
                    <i class="bi bi-clock me-1"></i>
                    <%= new Date(prox.fecha).toLocaleTimeString('es-ES', { hour: '2-digit', minute: '2-digit' }) %>
                </div>
            </div>

            <% if (typeof partida !== 'undefined' && prox.fecha.toDateString() === partida.fechaActual.toDateString()) { %>
                <div class="w-100 mt-4">
                    <a href="/jugar-partido/<%= prox._id %>" class="btn btn-success btn-lg w-100 fw-bold shadow-sm">
                        JUGAR AHORA
                    </a>
                </div>
            <% } %>
            
        </div>
    </div>
<% } else { %>
    <div class="card shadow-sm border-0 w-100">
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-calendar-x fs-1 opacity-50 mb-2"></i>
            <p class="mb-0 fw-bold">No hay partidos programados.</p>
        </div>
    </div>
<% } %>