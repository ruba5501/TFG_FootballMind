<div class="p-3">
    <div class="row border-bottom mb-3">
        <div>
            <h2 class="mb-2"><%= jugador.nombre %></h2>
            <span class="badge bg-primary fs-5">Media: <%= jugador.valoracion %></span>
            <span class="badge bg-primary fs-5">Potencial: <%= jugador.potencial %></span>
        </div>
        <p class="text-muted pt-3">
                <%= jugador.posicionPrincipal %> | 
                <%= jugador.nacionalidad %> 
                <img src="/img/banderas/<%= jugador.nacionalidad %>.png"
                    alt="<%= jugador.nacionalidad %>" 
                    class="ms-1 shadow-sm" 
                    style="height: 14px; width: auto; vertical-align: middle; border-radius: 2px;"
                > 
                | <%= jugador.edad %> años | <%= jugador.altura %>cm | <%= jugador.peso %>kg</p>
    </div>

    <ul class="nav nav-tabs mb-3" id="jugadorTabs" role="tablist">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-atributos">Atributos</button></li>
        <% if (jugador.clubActual._id.toString() === clubSeleccionado._id.toString()) { %>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-mercado">Contrato y Mercado</button></li>
        <% }else{ %>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-fichar">Ojear</button></li>
        <% } %>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-stats">Estadísticas</button></li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="tab-atributos">
            <%- include('atributosJugador', { jugador: jugador }) %>
        </div>

        <div class="tab-pane fade" id="tab-mercado">
            <div class="card p-3 mb-3">
                <p><strong>Salario:</strong> <%= (jugador.salario / 12).toLocaleString() %> €/mes (<%= jugador.salario.toLocaleString() %>)</p>
                <p><strong>Valor:</strong> <%= jugador.valorMercado.toLocaleString() %> €</p>
                <p><strong>Cláusula:</strong> 
                    <% if (jugador.mercado.clausulaRescision == 0) { %>
                        No tiene.
                    <% }else{ %>
                        <%= jugador.mercado.clausulaRescision.toLocaleString() %> €
                    <% } %>
                </p>
                <div class="d-grid gap-2">
                    <button class="btn btn-outline-warning" onclick="accionJugador('<%= jugador._id %>', 'transferible')">
                        <i class="bi bi- megaphone-fill me-1"></i>
                        <%= jugador.mercado.transferible ? 'Quitar de Transferibles' : 'Transferibles' %>
                    </button>
                    <button class="btn btn-outline-info" onclick="accionJugador('<%= jugador._id %>', 'cedible')">
                        <i class="bi bi- person- badge-fill me-1"></i>
                        <%= jugador.mercado.cedible ? 'Quitar de Cedibles' : 'Cedibles' %>
                    </button>
                    <% if (jugador.negociacionActiva) { %>
                        <% if (jugador.negociacionActiva.tipoObjetivo === 'Renovacion' || jugador.negociacionActiva.estadoTraspaso === 'aceptado') { %>
                            <button class="btn btn-warning" onclick="NegociarContrato(
                                '<%= jugador._id %>', 
                                '<%= jugador.negociacionActiva.ofertaSueldo || null %>', 
                                '<%= jugador.negociacionActiva.contraofertaSueldo || null %>',
                                '<%= jugador.negociacionActiva.contraofertaAños || null %>',
                                '<%= jugador.negociacionActiva.contraofertaRol %>',
                                '<%= jugador.negociacionActiva.contraofertaPrima || null %>',
                                '<%= jugador.negociacionActiva.ofertaAnios || null %>',
                                '<%= jugador.negociacionActiva.rolPrometido %>',
                                '<%= jugador.negociacionActiva.clausulaRescision || null %>',
                                '<%= jugador.negociacionActiva.PrimaContrato || null %>'
                            )">
                                <i class="bi bi-pen-fill me-1"></i> Ver Negociación de Contrato
                            </button>
                        <% } %>
                    <% } else { %>
                        <button class="btn btn-success" onclick="NegociarContrato('<%= jugador._id %>')">
                            <i class="bi bi-pen-fill me-1"></i> Renovar Contrato
                        </button>
                    <% } %>
                    <button class="btn btn-dark" onclick="abrirModalDorsal('<%= jugador._id %>')"><i class="bi bi- hash me-1"></i>Cambiar Dorsal</button>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-fichar">
            <div class="card p-3 mb-3 border-info">
                <p><strong>Salario:</strong> <%= (jugador.salario / 12).toLocaleString() %> €/mes (<%= jugador.salario.toLocaleString() %>)</p>
                <p><strong>Valor:</strong> <%= jugador.valorMercado.toLocaleString() %> €</p>
                <p><strong>Cláusula:</strong> 
                    <% if (jugador.mercado.clausulaRescision == 0) { %>
                        No tiene.
                    <% }else{ %>
                        <%= jugador.mercado.clausulaRescision.toLocaleString() %> €
                    <% } %>
                </p>
                <div class="d-grid gap-2" id="contenedor-boton-lista">
                    <% if (estaEnListaObjetivos) { %>
                        <button class="btn btn-outline-danger" onclick="gestionarListaObjetivos('<%= jugador._id %>', 'quitar', 'jugador')">
                            <i class="bi bi-eye-slash-fill me-1"></i> Quitar de la Lista
                        </button>
                    <% } else { %>
                        <button class="btn btn-outline-primary" onclick="gestionarListaObjetivos('<%= jugador._id %>', 'aniadir', 'jugador')">
                            <i class="bi bi-eye-fill me-1"></i> Añadir a Lista de Objetivos
                        </button>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-stats">
            <% if (jugador.statsTemporada && jugador.statsTemporada.length > 0) { %>
                <div class="table-responsive">
                    <table class="table table-sm table-hover small">
                        <thead class="table-light">
                            <tr>
                                <th>Competición</th>
                                <th class="text-center">PJ</th>
                                <th class="text-center">PT</th>
                                <th class="text-center">G</th>
                                <th class="text-center">A</th>
                                <th class="text-center">PI</th>
                                <th class="text-center">TA</th>
                                <th class="text-center">TR</th>
                                <th class="text-center">Mins</th>
                                <th class="text-center">Nota</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% jugador.statsTemporada.forEach(stat => { %>
                                <tr>
                                    <td><%= stat.competicionId ? stat.competicionId.nombre : 'General' %></td>
                                    <td class="text-center"><%= stat.pj %></td>
                                    <td class="text-center"><%= stat.titular %></td>
                                    <td class="text-center"><%= stat.goles %></td>
                                    <td class="text-center"><%= stat.asistencias %></td>
                                    <td class="text-center"><%= stat.porteriasACero %></td>
                                    <td class="text-center"><%= stat.amarillas %></td>
                                    <td class="text-center"><%= stat.rojas %></td>
                                    <td class="text-center"><%= stat.minutos %></td>
                                    <td class="text-center">
                                        <span class="badge <%= stat.notaMedia >= 7 ? 'bg-success' : 'bg-secondary' %>">
                                            <%= stat.notaMedia.toFixed(2) %>
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                            <% 
                                let tPJ = 0, tPT = 0, tG = 0, tA = 0, tPI = 0, tTA = 0, tTR = 0, tMins = 0, sumaNotas = 0;
                                jugador.statsTemporada.forEach(s => {
                                    tPJ += s.pj; tPT += s.titular; tG += s.goles; tA += s.asistencias;
                                    tPI += (s.porteriasACero || 0); tTA += s.amarillas; tTR += s.rojas;
                                    tMins += s.minutos; sumaNotas += (s.notaMedia * s.pj);
                                });
                                let notaFinal = tPJ > 0 ? (sumaNotas / tPJ).toFixed(2) : "0.00";
                            %>
                            <tr class="table-dark fw-bold border-top border-primary">
                                <td>TOTAL TEMPORADA</td>
                                <td class="text-center"><%= tPJ %></td>
                                <td class="text-center"><%= tPT %></td>
                                <td class="text-center"><%= tG %></td>
                                <td class="text-center"><%= tA %></td>
                                <td class="text-center"><%= tPI %></td>
                                <td class="text-center"><%= tTA %></td>
                                <td class="text-center"><%= tTR %></td>
                                <td class="text-center"><%= tMins %></td>
                                <td class="text-center">
                                    <span class="badge bg-primary"><%= notaFinal %></span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('modal_contratos') %>