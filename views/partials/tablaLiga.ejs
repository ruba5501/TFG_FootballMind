<% if (competicion.tipo === 'internacional_europa' && competicion.faseActual === 'eliminatorias') { %>
    <div class="alert alert-info d-flex justify-content-between align-items-center shadow-sm border-0 mb-4">
        <div>
            <i class="bi bi-info-circle-fill me-2"></i>
            <strong>Fase de grupos finalizada.</strong> Ya puedes consultar los cruces.
        </div>
        
        <% if (typeof partida !== 'undefined' && partida) { %>
            <a href="/copa/<%= partida._id %>/<%= competicion._id %>" class="btn btn-primary btn-sm">
                <i class="bi bi-diagram-3 me-2"></i>Ver Eliminatorias
            </a>
        <% } else { %>
            <button onclick="cargarInfo('<%= competicion._id %>', 'copa')" 
                    class="btn btn-primary btn-sm shadow-sm">
                <i class="bi bi-diagram-3 me-2"></i>Ver Eliminatorias
            </button>
        <% } %>
    </div>
<% } %>

<%- include('jornadas') %>

<div class="card shadow border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr class="text-center">
                        <th scope="col" class="py-3" style="width: 50px;">Pos</th>
                        <th scope="col" class="py-3 text-start">Club</th>
                        <th scope="col" class="py-3 px-3 fs-6" title="Puntos">PTS</th>
                        <th scope="col" class="py-3">PJ</th>
                        <th scope="col" class="py-3">PG</th>
                        <th scope="col" class="py-3">PE</th>
                        <th scope="col" class="py-3">PP</th>
                        <th scope="col" class="py-3">GF</th>
                        <th scope="col" class="py-3">GC</th>
                        <th scope="col" class="py-3">DIF</th>
                    </tr>
                </thead>
                <tbody>
                    <% clasificacion.forEach((fila, index) => { 
                        let esUsuario = clubUsuario && fila.club._id.toString() === clubUsuario._id.toString();
                        let bgClass = esUsuario ? 'table-primary border-primary' : '';
                    %>
                        <tr class="text-center <%= bgClass %>">
                            <td class="fw-bold <%= index < 4 ? 'text-success' : (index > clasificacion.length - 4 ? 'text-danger' : '') %>">
                                <%= index + 1 %>
                            </td>
                            <td class="text-start fw-semibold">
                                <img src="/img/escudos/<%= fila.club.escudo %>" alt="<%= fila.club.nombre %>" width="30" class="me-2 drop-shadow-sm">
                                <%= fila.club.nombre %>
                            </td>
                            <td class="fw-bold fs-5 px-3"><%= fila.pts %></td>
                            <td><%= fila.pj %></td>
                            <td><%= fila.pg %></td>
                            <td><%= fila.pe %></td>
                            <td><%= fila.pp %></td>
                            <td><%= fila.gf %></td>
                            <td><%= fila.gc %></td>
                            <td>
                                <% let dif = fila.gf - fila.gc; %>
                                <span class="<%= dif > 0 ? 'text-success' : (dif < 0 ? 'text-danger' : 'text-muted') %> fw-bold">
                                    <%= dif > 0 ? '+' + dif : dif %>
                                </span>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
