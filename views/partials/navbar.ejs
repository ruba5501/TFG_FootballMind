<header>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
    <a class="navbar-brand ms-4 fw-bold" href="<%= (typeof partida !== 'undefined' && partida) ? '/inicioJuego/' + partida._id : '/' %>">
      FootballMind
    </a>
    
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto me-4">
        
        <% if (typeof partida !== 'undefined' && partida) { %>
          <li class="nav-item">
            <a class="nav-link" href="/inicioJuego/<%= partida._id %>"><i class="bi bi-house-door me-1"></i> Inicio</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/plantilla/<%= partida._id %>"><i class="bi bi-person-badge me-1"></i> Plantilla</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/formacion/<%= partida._id %>"><i class="bi bi-grid-3x3-gap-fill me-1"></i> Formación</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/empleados/<%= partida._id %>"><i class="bi bi-person-workspace me-1"></i> Empleados</a>
          </li>
          <% if (typeof partida.clubSeleccionado !== 'undefined' && !partida.clubSeleccionado.esFilial) { %>
            <li class="nav-item">
              <a class="nav-link" href="/cantera/<%= partida._id %>"><i class="bi bi-mortarboard me-1"></i> Cantera</a>
            </li>
          <% } %>
          <li class="nav-item">
            <a class="nav-link" href="/traspasos/<%= partida._id %>"><i class="bi bi-currency-exchange me-1"></i> Traspasos</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/competicones/<%= partida._id %>"><i class="bi bi-trophy me-1"></i> Competiciones</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/calendario/<%= partida._id %>"><i class="bi bi-calendar3 me-1"></i> Calendario</a>
          </li>
          <li class="nav-item">
            <a class="nav-link text-warning fw-bold" href="/partida/<%= partida._id %>">
              <i class="bi bi-box-arrow-right me-1"></i> Salir de partida
            </a>
          </li>

        <% } else { %>
          <% if (user) { %>
            <li class="nav-item">
              <a class="nav-link" href="/opcionPartida">Inicio</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/perfil">Perfil</a>
            </li>
            <li class="nav-item">
              <form action="/logout" method="POST" class="m-0">
                <button type="submit" class="nav-link btn btn-link text-danger border-0">Cerrar sesión</button>
              </form>
            </li>
          <% } else { %>
            <li class="nav-item">
              <a class="nav-link" href="/index">Iniciar Sesion</a>
            </li>
            <% } %>
        <% } %>
      </ul>
    </div>
  </nav>
</header>
