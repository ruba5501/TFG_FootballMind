<div class="modal fade" id="modalRoles" tabindex="-1" aria-labelledby="modalRolesLabel" aria-hidden="true">
    <div class="modal-dialog modal-md">
        <div class="modal-content bg-dark text-white border-primary">
            <div class="modal-header border-secondary">
                <h5 class="modal-title" id="modalRolesLabel"><i class="bi bi-person-badge"></i> Roles del Equipo</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formRoles">
                    <div class="mb-3">
                        <label class="form-label text-warning small fw-bold">CAPITÁN</label>
                        <select name="capitan" class="form-select bg-secondary text-white border-0">
                            <% clubUsuario.plantilla.forEach(j => { %>
                                <option value="<%= j._id %>" <%= (clubUsuario.tactica && clubUsuario.tactica.capitan == j._id.toString()) ? 'selected' : '' %>><%= j.nombre %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-info small fw-bold">PENALTIS</label>
                        <select name="penaltis" class="form-select bg-secondary text-white border-0">
                            <% clubUsuario.plantilla.forEach(j => { %>
                                <option value="<%= j._id %>" <%= (clubUsuario.tactica && clubUsuario.tactica.penaltis == j._id.toString()) ? 'selected' : '' %>><%= j.nombre %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-info small fw-bold">FALTAS IZQUIERDA</label>
                        <select name="penaltis" class="form-select bg-secondary text-white border-0">
                            <% clubUsuario.plantilla.forEach(j => { %>
                                <option value="<%= j._id %>" <%= (clubUsuario.tactica && clubUsuario.tactica.faltasIzquierda == j._id.toString()) ? 'selected' : '' %>><%= j.nombre %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-info small fw-bold">FALTAS DERECHA</label>
                        <select name="penaltis" class="form-select bg-secondary text-white border-0">
                            <% clubUsuario.plantilla.forEach(j => { %>
                                <option value="<%= j._id %>" <%= (clubUsuario.tactica && clubUsuario.tactica.faltasDerecha == j._id.toString()) ? 'selected' : '' %>><%= j.nombre %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-info small fw-bold">FALTAS LEJANAS</label>
                        <select name="penaltis" class="form-select bg-secondary text-white border-0">
                            <% clubUsuario.plantilla.forEach(j => { %>
                                <option value="<%= j._id %>" <%= (clubUsuario.tactica && clubUsuario.tactica.faltasLejanas == j._id.toString()) ? 'selected' : '' %>><%= j.nombre %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-info small fw-bold">CORNER IZQUIERDO</label>
                        <select name="penaltis" class="form-select bg-secondary text-white border-0">
                            <% clubUsuario.plantilla.forEach(j => { %>
                                <option value="<%= j._id %>" <%= (clubUsuario.tactica && clubUsuario.tactica.cornersIzquierda == j._id.toString()) ? 'selected' : '' %>><%= j.nombre %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-info small fw-bold">CORNER DERECHO</label>
                        <select name="penaltis" class="form-select bg-secondary text-white border-0">
                            <% clubUsuario.plantilla.forEach(j => { %>
                                <option value="<%= j._id %>" <%= (clubUsuario.tactica && clubUsuario.tactica.cornersDerecha == j._id.toString()) ? 'selected' : '' %>><%= j.nombre %></option>
                            <% }) %>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-secondary">
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" onclick="GestorTactico.guardarRoles('<%= clubUsuario._id %>')">Guardar Roles</button>
            </div>
        </div>
    </div>
</div>
