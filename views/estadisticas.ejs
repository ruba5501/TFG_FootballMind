    <%- include('partials/head', {title: title}) %>
    <%- include('partials/navbar') %>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-white"><i class="bi bi-bar-chart-line-fill text-info me-2"></i> Estadísticas del Club</h2>
        </div>

        <div class="card shadow-sm border-0 bg-dark text-white mb-4">
            <div class="card-header bg-secondary fw-bold text-uppercase">
                <i class="bi bi-diagram-3-fill me-2"></i> Rendimiento por Formación Táctica
            </div>
            <div class="card-body p-0">
                <% if (Object.keys(statsFormaciones).length === 0) { %>
                    <div class="p-5 text-center text-muted">
                        <i class="bi bi-cone-striped display-1"></i>
                        <p class="mt-3">Aún no hay datos. Juega algunos partidos para que el sistema recopile estadísticas.</p>
                    </div>
                <% } else { %>
                    <div class="table-responsive">
                        <table class="table table-dark table-hover align-middle mb-0 text-center">
                            <thead class="table-light text-dark">
                                <tr>
                                    <th class="text-start ps-4">Formación</th>
                                    <th>PJ</th>
                                    <th class="text-success">PG</th>
                                    <th class="text-warning">PE</th>
                                    <th class="text-danger">PP</th>
                                    <th>GF</th>
                                    <th>GC</th>
                                    <th>DIF</th>
                                    <th>Puntos</th>
                                    <th>% Victorias</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% Object.keys(statsFormaciones).sort((a, b) => statsFormaciones[b].pts - statsFormaciones[a].pts).forEach(f => { 
                                    let s = statsFormaciones[f];
                                    let dif = s.gf - s.gc;
                                    let porcentaje = ((s.pg / s.pj) * 100).toFixed(1);
                                %>
                                    <tr>
                                        <td class="text-start ps-4 fw-bold text-info"><%= f %></td>
                                        <td><%= s.pj %></td>
                                        <td><%= s.pg %></td>
                                        <td><%= s.pe %></td>
                                        <td><%= s.pp %></td>
                                        <td><%= s.gf %></td>
                                        <td><%= s.gc %></td>
                                        <td class="<%= dif > 0 ? 'text-success' : (dif < 0 ? 'text-danger' : '') %>">
                                            <%= dif > 0 ? '+' + dif : dif %>
                                        </td>
                                        <td class="fw-bold fs-5"><%= s.pts %></td>
                                        <td>
                                            <div class="progress" style="height: 15px;">
                                                <div class="progress-bar <%= porcentaje > 50 ? 'bg-success' : (porcentaje > 30 ? 'bg-warning' : 'bg-danger') %>" 
                                                    role="progressbar" style="width: <%= porcentaje %>%;">
                                                    <%= porcentaje %>%
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </div>
        </div>
        <!-- NUEVA SECCIÓN: RENDIMIENTO INDIVIDUAL -->
        <h4 class="text-white mt-5 mb-3"><i class="bi bi-star-fill text-warning me-2"></i> Rendimiento Individual</h4>
        <div class="row g-4 mb-5">
            
            <!-- Máximos Goleadores -->
            <div class="col-md-6 col-lg-3">
                <div class="card shadow-sm border-0 bg-dark text-white h-100">
                    <div class="card-header bg-danger fw-bold">
                        <i class="bi bi-bullseye me-2"></i> Goleadores
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            <% if (topGoleadores.length === 0) { %>
                                <li class="list-group-item bg-dark text-muted text-center py-3">Nadie ha marcado aún</li>
                            <% } else { %>
                                <% topGoleadores.forEach((j, index) => { %>
                                    <li class="list-group-item bg-dark text-white d-flex justify-content-between align-items-center">
                                        <div class="text-truncate me-2">
                                            <strong><%= index + 1 %>.</strong> <%= j.nombre %>
                                            <span class="badge bg-secondary ms-1" style="font-size: 0.65rem;"><%= j.posicion %></span>
                                        </div>
                                        <span class="badge bg-danger rounded-pill fs-6"><%= j.goles %></span>
                                    </li>
                                <% }) %>
                            <% } %>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Máximos Asistentes -->
            <div class="col-md-6 col-lg-3">
                <div class="card shadow-sm border-0 bg-dark text-white h-100">
                    <div class="card-header bg-info text-dark fw-bold">
                        <i class="bi bi-lightning-fill me-2"></i> Asistencias
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            <% if (topAsistentes.length === 0) { %>
                                <li class="list-group-item bg-dark text-muted text-center py-3">Sin asistencias registradas</li>
                            <% } else { %>
                                <% topAsistentes.forEach((j, index) => { %>
                                    <li class="list-group-item bg-dark text-white d-flex justify-content-between align-items-center">
                                        <div class="text-truncate me-2">
                                            <strong><%= index + 1 %>.</strong> <%= j.nombre %>
                                        </div>
                                        <span class="badge bg-info text-dark rounded-pill fs-6"><%= j.asistencias %></span>
                                    </li>
                                <% }) %>
                            <% } %>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Mejor Nota Media -->
            <div class="col-md-6 col-lg-3">
                <div class="card shadow-sm border-0 bg-dark text-white h-100">
                    <div class="card-header bg-success fw-bold">
                        <i class="bi bi-activity me-2"></i> Mejor Media
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            <% if (topNotas.length === 0) { %>
                                <li class="list-group-item bg-dark text-muted text-center py-3">Sin valoraciones</li>
                            <% } else { %>
                                <% topNotas.forEach((j, index) => { %>
                                    <li class="list-group-item bg-dark text-white d-flex justify-content-between align-items-center">
                                        <div class="text-truncate me-2">
                                            <strong><%= index + 1 %>.</strong> <%= j.nombre %>
                                        </div>
                                        <span class="badge bg-success rounded-pill fs-6"><%= j.notaMedia %></span>
                                    </li>
                                <% }) %>
                            <% } %>
                        </ul>
                    </div>
                </div>
            </div>

            <!-- Más Minutos Jugados -->
            <div class="col-md-6 col-lg-3">
                <div class="card shadow-sm border-0 bg-dark text-white h-100">
                    <div class="card-header bg-warning text-dark fw-bold">
                        <i class="bi bi-stopwatch-fill me-2"></i> Minutos
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            <% if (topMinutos.length === 0) { %>
                                <li class="list-group-item bg-dark text-muted text-center py-3">Nadie ha jugado aún</li>
                            <% } else { %>
                                <% topMinutos.forEach((j, index) => { %>
                                    <li class="list-group-item bg-dark text-white d-flex justify-content-between align-items-center">
                                        <div class="text-truncate me-2">
                                            <strong><%= index + 1 %>.</strong> <%= j.nombre %>
                                        </div>
                                        <span class="badge bg-warning text-dark rounded-pill fs-6"><%= j.minutos %>'</span>
                                    </li>
                                <% }) %>
                            <% } %>
                        </ul>
                    </div>
                </div>
            </div>

        </div>
    </div>