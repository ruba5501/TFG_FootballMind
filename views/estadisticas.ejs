<%- include('partials/head') %>
<%- include('partials/navbar') %>

<div class="container mt-4 mb-5">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="fw-bold text-center border-bottom pb-3">
                <i class="bi bi-bar-chart-line text-primary"></i> Centro de Estadísticas
            </h1>
            <p class="text-muted text-center">Análisis de rendimiento global de la partida.</p>
        </div>
    </div>

    <h3 class="mb-3"><i class="bi bi-person-stars"></i> Estadísticas de Jugadores</h3>
    <div class="row g-4 mb-5">
        
        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-danger text-white fw-bold">
                    <i class="bi bi-bullseye"></i> Pichichi (Goleadores)
                </div>
                <ul class="list-group list-group-flush">
                    <% topGoleadores.forEach((jugador, index) => { %>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><strong><%= index + 1 %>.</strong> <%= jugador.nombre %> <br><small class="text-muted"><%= jugador.clubActual?.nombre %></small></span>
                            <span class="badge bg-danger rounded-pill"><%= jugador.totalGoles %> goles</span>
                        </li>
                    <% }) %>
                </ul>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-success text-white fw-bold">
                    <i class="bi bi-lightning-charge"></i> Máximos Asistentes
                </div>
                <ul class="list-group list-group-flush">
                    <% topAsistentes.forEach((jugador, index) => { %>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><strong><%= index + 1 %>.</strong> <%= jugador.nombre %> <br><small class="text-muted"><%= jugador.clubActual?.nombre %></small></span>
                            <span class="badge bg-success rounded-pill"><%= jugador.totalAsistencias %> asis.</span>
                        </li>
                    <% }) %>
                </ul>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-warning text-dark fw-bold">
                    <i class="bi bi-star-fill"></i> MVP (Mejor Nota)
                </div>
                <ul class="list-group list-group-flush">
                    <% topMVP.forEach((jugador, index) => { %>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><strong><%= index + 1 %>.</strong> <%= jugador.nombre %> <br><small class="text-muted"><%= jugador.clubActual?.nombre %></small></span>
                            <span class="badge bg-warning text-dark rounded-pill"><%= jugador.mejorNota %> media</span>
                        </li>
                    <% }) %>
                </ul>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-header bg-info text-white fw-bold">
                    <i class="bi bi-graph-up-arrow"></i> Más Valorados
                </div>
                <ul class="list-group list-group-flush">
                    <% topValorados.forEach((jugador, index) => { %>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><strong><%= index + 1 %>.</strong> <%= jugador.nombre %> <br><small class="text-muted"><%= jugador.clubActual?.nombre %></small></span>
                            <span class="badge bg-info rounded-pill"><%= jugador.valoracion %> OVR</span>
                        </li>
                    <% }) %>
                </ul>
            </div>
        </div>
    </div>

    <h3 class="mb-3"><i class="bi bi-diagram-3"></i> Táctica y Rendimiento Global</h3>
    <div class="row g-4">
        
        <div class="col-md-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white fw-bold">
                    <i class="bi bi-controller"></i> Las Mejores Formaciones del Juego
                </div>
                <div class="card-body">
                    <p class="text-muted small">Cálculo basado en los puntos por partido obtenidos por los clubes que utilizan cada formación como principal.</p>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Rank</th>
                                    <th>Formación</th>
                                    <th>Pts por Partido (PPP)</th>
                                    <th>Equipos que la usan</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% formacionesRendimiento.forEach((form, index) => { %>
                                    <tr>
                                        <td><strong>#<%= index + 1 %></strong></td>
                                        <td><span class="badge bg-secondary"><%= form.formacion %></span></td>
                                        <td><span class="fw-bold text-success"><%= form.ppp %></span> pts</td>
                                        <td><%= form.equiposQueLaUsan %> equipos</td>
                                    </tr>
                                <% }) %>
                                <% if(formacionesRendimiento.length === 0) { %>
                                    <tr>
                                        <td colspan="4" class="text-center text-muted">Aún no hay suficientes partidos simulados.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>