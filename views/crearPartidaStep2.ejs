<%- include('partials/head', {title: 'Crear Partida - Selección de Club'}) %>
<link rel="stylesheet" href="/css/styles.css">

<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-10 col-lg-8">
      
      <div class="card shadow card-crear-partida">
        <div class="card-header bg-primary text-white text-center py-3">
          <h2 class="h4 mb-0">Selecciona Liga y Club</h2>
        </div>
        
        <div class="card-body p-4 text-center">
          <% if(error) { %>
            <div class="alert alert-danger"><%= error %></div>
          <% } %>

          <form method="POST" action="/crearPartida/step2" id="formStep2">
            
            <div class="mb-5">
              <h5 class="text-muted mb-4 text-uppercase fw-bold small">1. Elige una Competición</h5>
              <div class="carousel-container">
                <button type="button" class="arrow-btn" onclick="moveCarousel('liga', -1)">❮</button>
                
                <div id="liga-display" class="flex-grow-1">
                  <% ligas.forEach((l, index) => { %>
                    <div class="liga-item d-none" id="liga-<%= index %>" data-id="<%= l._id %>">
                      <img src="/img/logos/<%= l.logo %>" 
                           class="img-thumbnail selector-img" 
                           onclick="confirmarLiga('<%= index %>')">
                      <div class="mt-3 d-flex align-items-center justify-content-center">
                        <img src="/img/banderas/<%= l.pais %>.png" class="bandera-liga">
                        <span class="h5 mb-0"><%= l.nombre %></span>
                      </div>
                    </div>
                  <% }) %>
                </div>

                <button type="button" class="arrow-btn" onclick="moveCarousel('liga', 1)">❯</button>
              </div>
              <input type="hidden" name="ligaSelect" id="ligaInput" required>
            </div>

            <div id="seccion-clubes" class="d-none">
              <hr class="my-5">
              <h5 class="text-muted mb-4 text-uppercase fw-bold small">2. Selecciona tu Equipo</h5>
              <div class="carousel-container">
                <button type="button" class="arrow-btn" onclick="moveCarousel('club', -1)">❮</button>
                
                <div id="club-display" class="flex-grow-1">
                  <% clubes.forEach((c) => { 
                      const idL = (c.competiciones && c.competiciones._id) ? c.competiciones._id : c.competiciones;
                  %>
                    <div class="club-item d-none" data-liga-id="<%= idL %>">
                      <img src="/img/escudos/<%= c.escudo %>" 
                          class="img-thumbnail selector-img" 
                          onclick="confirmarClub(this, '<%= c._id %>')">
                      <div class="mt-3 h5 fw-bold"><%= c.nombre %></div>
                    </div>
                  <% }) %>
                </div>

                <button type="button" class="arrow-btn" onclick="moveCarousel('club', 1)">❯</button>
              </div>
              <input type="hidden" name="club" id="clubInput" required>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top flex-wrap gap-2">
              <a href="/crearPartida/step1" class="btn btn-outline-secondary btn-lg px-4">
                Atrás
              </a>
              <a href="/opcionPartida" class="btn btn-outline-danger btn-lg px-4"
                onclick="return confirm('¿Estás seguro de que deseas cancelar? Se perderán todos los datos introducidos.')">
                Cancelar
              </a>
              <button type="submit" class="btn btn-primary btn-lg px-5 shadow-sm">
                Siguiente Paso
              </button>
            </div>

          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<script defer src="/js/seleccionLigasEquipos.js"></script>