<%- include('partials/head', {title: 'Plantilla'}) %>
<%- include('partials/navbar') %>

<div class="container-fluid mt-3">
    <div class="row">
        <div class="col-md-7 border-end" style="height: 85vh; overflow-y: auto;">
            <h4 class="mb-2">Plantilla: <%= clubUsuario.nombre %>
            <img src="/img/escudos/<%= clubUsuario.escudo %>"
                    alt="<%= clubUsuario.escudo %>" 
                    class="ms-1 shadow-sm" 
                    style="height: 50px; width: auto; vertical-align: middle; border-radius: 2px;"
                > 
            </h4>
            <table class="table table-dark table-hover align-middle shadow-sm border">
                <thead>
                    <tr class="small text-muted text-uppercase border">
                        <th>Dorsal</th>
                        <th>Jugador</th>
                        <th>Pos</th>
                        <th>Edad</th>
                        <th>Rol</th>
                        <th>Satisfacción</th>
                        <th>Moral</th>
                        <th>Lesión</th>
                    </tr>
                </thead>
                <tbody>
                    <% jugadores.forEach(j => { %>
                        <tr style="cursor: pointer;" onclick="verDetalleJugador('<%= j._id %>')">
                            <td class="fw-bold text-info"><%= j.dorsal %></td>
                            <td><div><%= j.nombre %></div></td>
                            <td><span class="badge bg-secondary"><%= j.posicionPrincipal %></span></td>
                            <td><%= j.edad %> años</td>
                            <td><%= j.rolEquipo %></td>
                            <td>
                                <i class="bi bi-emoji-smile text-<%= j.estado.satisfaccion > 70 ? 'success' : 'warning' %>"></i>
                            </td>
                            <td>
                                <i class="bi bi-emoji-smile text-<%= j.estado.moral > 70 ? 'success' : 'warning' %>"></i>
                            </td>
                            <td>
                                <% if(j.estado.lesion) { %><i class="bi bi-plus-circle-fill text-danger ms-1"></i><% } %>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <div class="col-md-5 bg-light" id="panelDetalleJugador" style="height: 85vh; overflow-y: auto;">
            <div class="text-center mt-5">
                <i class="bi bi-person-bounding-box display-1 text-muted"></i>
                <p>Selecciona un jugador para ver sus atributos y estadísticas</p>
            </div>
        </div>
    </div>
</div>

<%- include('partials/modalDorsal') %>
<script>
    // Guardamos el ID del club en una variable global de JS
    const CLUB_ID_ACTUAL = '<%= clubUsuario._id %>';
</script>
<script src="/js/plantilla.js"></script>