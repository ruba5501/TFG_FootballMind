<%- include('partials/head', {title: 'Calendario'}) %>
<header>
  <%- include('partials/navbar') %>
</header>
<div class="container mt-4">
    <div class="row">
        <div class="col-md-9">
            <div class="calendar-header d-flex justify-content-between align-items-center mb-3">
                <% 
                    let prevMes = calendario.mes === 0 ? 11 : calendario.mes - 1;
                    let prevAnio = calendario.mes === 0 ? calendario.anio - 1 : calendario.anio;
                    let nextMes = calendario.mes === 11 ? 0 : calendario.mes + 1;
                    let nextAnio = calendario.mes === 11 ? calendario.anio + 1 : calendario.anio;
                %>
                <a href="?mes=<%= prevMes %>&anio=<%= prevAnio %>" class="btn btn-dark">&lt;</a>
                <h2 class="text-capitalize"><%= calendario.nombreMes %> <%= calendario.anio %></h2>
                <a href="?mes=<%= nextMes %>&anio=<%= nextAnio %>" class="btn btn-dark">&gt;</a>
            </div>
            
            <div class="calendar-grid">
                <div class="day-name">Lun</div><div class="day-name">Mar</div><div class="day-name">Mié</div>
                <div class="day-name">Jue</div><div class="day-name">Vie</div><div class="day-name">Sáb</div>
                <div class="day-name">Dom</div>

                <% for(let x = 0; x < calendario.offset; x++) { %>
                    <div class="calendar-day other-month"></div>
                <% } %>

                <% for(let d = 1; d <= calendario.diasEnMes; d++) { 
                    let esHoy = d === partida.fechaActual.getDate() && calendario.mes === partida.fechaActual.getMonth();
                    let partidoHoy = partidos.find(p => p.fecha.getDate() === d);
                %>
                    <div class="calendar-day <%= esHoy ? 'today' : '' %>">
                        <span class="fw-bold"><%= d %></span>
                        
                        <% if (partidoHoy) { 
                            let esLocal = partidoHoy.equipoLocal._id.toString() === clubUsuario._id.toString();
                            let rival = esLocal ? partidoHoy.equipoVisitante : partidoHoy.equipoLocal;
                            let nombreComp = partidoHoy.competicionId.nombre.toLowerCase();
                            let tipoComp = partidoHoy.competicionId.tipo;
                            let claseComp = ''; 
                            if (nombreComp.includes('laliga')) {
                                claseComp = 'bg-laliga';
                            } 
                            else if (nombreComp.includes('premier')) {
                                claseComp = 'bg-premier';
                            }
                            else if (nombreComp.includes('serie a')) {
                                claseComp = 'bg-seriea';
                            }
                            else if (nombreComp.includes('bundesliga')) {
                                claseComp = 'bg-bundesliga';
                            }
                            else if (nombreComp.includes('ligue 1')) {
                                claseComp = 'bg-ligue1';
                            }
                            else if (nombreComp.includes('eredivisie')) {
                                claseComp = 'bg-eredivisie';
                            }
                            else if (nombreComp.includes('primeira liga')) {
                                claseComp = 'bg-primeriraliga';
                            }
                            else if (nombreComp.includes('argentina')) {
                                claseComp = 'bg-argentina';
                            }
                            else if (nombreComp.includes('brasileirão')) {
                                claseComp = 'bg-brasileirão';
                            }
                            else if (nombreComp.includes('champions')) {
                                claseComp = 'bg-champions';
                            }
                            else if (nombreComp.includes('europa')) {
                                claseComp = 'bg-europa';
                            }
                            else if (nombreComp.includes('conference')) {
                                claseComp = 'bg-conference';
                            }
                            else if (nombreComp.includes('libertadores')) {
                                claseComp = 'bg-libertadores';
                            }
                            else if (nombreComp.includes('sudamericana')) {
                                claseComp = 'bg-sudamericana';
                            }
                            else if (tipoComp === 'copa') {
                                claseComp = 'bg-copa';
                            }                       
                            %>
                            <div class="match-tag <%= claseComp %> text-center mt-1">
                                <div class="small fw-bold"><%= esLocal ? '(Local)' : '(Visitante)' %></div>
                                <img src="/img/escudos/<%= rival.escudo %>" width="25">
                                <div style="font-size: 0.6rem;"><%= rival.nombre %></div>
                            </div>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </div>

        <div class="col-md-3">
            <%- include('partials/proximoPartido', { proximoPartido, proximoPartido, clubUsuario }) %>
        </div>
    </div>
</div>