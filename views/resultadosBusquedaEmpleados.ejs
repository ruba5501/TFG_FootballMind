<%- include('partials/head', {title: 'Resultados de Búsqueda'}) %>
<%- include('partials/navbar') %>

<div class="container-fluid mt-3">
    <div class="row">
        <div class="col-md-7 border-end" style="height: 85vh; overflow-y: auto;">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4>Empleados encontrados (<%= empleados.length %>)</h4>
                <a href="/empleados/<%= partida._id %>" class="btn btn-sm btn-outline-secondary">Volver al buscador</a>
            </div>
            
            <table class="table table-dark table-hover align-middle shadow-sm">
                <thead>
                    <tr class="small text-muted text-uppercase">
                        <th>Empleado</th>
                        <th>Club</th>
                        <th>Cargo</th>
                        <th>Edad</th>
                    </tr>
                </thead>
                <tbody>
                    <% empleados.forEach(e => { %>
                        <tr style="cursor: pointer;" onclick="verDetalleEmpleado('<%= e._id %>')">
                            <td><div class="fw-bold"><%= e.nombre %></div></td>
                            <td>
                                <% if (e.clubActual) { %>
                                    <img src="/img/escudos/<%= e.clubActual.escudo %>" 
                                        alt="<%= e.clubActual.nombre %>" 
                                        class="ms-1 shadow-sm" 
                                        style="height: 30px; width: auto; vertical-align: middle; border-radius: 2px;">
                                <% } else { %>
                                    <span class="text-muted italic">Agente Libre</span>
                                <% } %>
                            </td>
                            <td><span class="badge bg-secondary"><%= e.tipo %></span></td>
                            <td><%= e.edad %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <div class="col-md-5 bg-light" id="panelDetalleEmpleado" style="height: 85vh; overflow-y: auto;">
            <div class="text-center mt-5 text-muted">
                <i class="bi bi-search display-1"></i>
                <p>Haz clic en un empleado para ver el informe detallado</p>
            </div>
        </div>
    </div>
</div>

<script src="/js/plantilla.js"></script>