<%- include('partials/head', {title: 'Centro de Mando - FootballMind'}) %>
<header>
  <%- include('partials/navbar') %>
</header>

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card bg-dark text-white shadow">
                <div class="card-body d-flex align-items-center justify-content-between p-4">
                    <div>
                        <h2 class="mb-1 fw-bold"><%= clubUsuario.nombre %></h2>
                        <p class="mb-0 text-light opacity-75">
                            <i class="bi bi-person-fill me-1"></i> Mánager: <%= user.username %> | Temporada Inicial
                        </p>
                    </div>
                    <div>
                        <img src="/img/escudos/<%= clubUsuario.escudo %>" alt="Escudo" width="90" class="drop-shadow">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-5 mb-4 d-flex flex-column align-items-stretch">
            
            <%- include('partials/proximoPartido', { partidos, clubUsuario, partida, proximoPartido }) %>
            
            <div class="card shadow-sm border-0 mt-3">
                <div class="card-body text-center p-3">
                    <p class="small text-muted mb-3">
                        Fecha actual: <span class="fw-bold text-dark fs-6"><%= new Date(partida.fechaActual).toLocaleDateString('es-ES', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %></span>
                    </p>

                    <% 
                        // Comprobamos si el partido más próximo es HOY
                        const esDiaDePartido = proximoPartido && new Date(proximoPartido.fecha).toDateString() === new Date(partida.fechaActual).toDateString();
                    %>

                    <% if (esDiaDePartido) { %>
                        <div class="alert alert-success py-2 mb-3">
                            <p class="fw-bold mb-0 small"><i class="bi bi-exclamation-circle-fill me-1"></i> ¡Día de partido!</p>
                            <small class="text-dark"><%= proximoPartido.competicionId?.nombre || 'Competición' %></small>
                        </div>
                    <% } else if (proximoPartido) { %>
                        <a href="/avanzar-fecha/<%= partida._id %>" class="btn btn-dark w-100 fw-bold shadow-sm mb-2" 
                        onclick="mostrarCarga('Avanzando un día...', 'Simulando resultados y mercado...')">
                            <i class="bi bi-step-forward-fill me-1"></i> AVANZAR DÍA
                        </a>
                        
                        <a href="/avanzar-hasta-partido/<%= partida._id %>" class="btn btn-outline-dark w-100 fw-bold shadow-sm" 
                        onclick="mostrarCarga('Saltando días...', 'Simulando competiciones intermedias...')">
                            <i class="bi bi-fast-forward-fill me-1"></i> IR AL PRÓXIMO PARTIDO
                        </a>

                    <% } else { %>
                        <a href="/avanzar-fecha/<%= partida._id %>" class="btn btn-secondary w-100 fw-bold shadow-sm">
                            <i class="bi bi-forward-fill me-1"></i> FINALIZAR TEMPORADA
                        </a>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="col-md-7 mb-4">
            <div class="row g-3">
                <div class="col-sm-6">
                    <div class="card shadow-sm border-0 h-100 hover-card">
                        <div class="card-body text-center p-4">
                            <h5 class="card-title fw-bold text-dark mb-3">Competiciones</h5>
                            <p class="text-muted small mb-4">Revisa la clasificación de liga y el avance en copa.</p>
                            <a href="/mis-competiciones/<%= partida._id %>" class="btn btn-outline-dark w-100 mb-2">Ver Mis Competiciones</a>
                            <a href="/calendario/<%= partida._id %>" class="btn btn-outline-dark w-100">Ver Calendario</a>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="card shadow-sm border-0 h-100 hover-card">
                        <div class="card-body text-center p-4">
                            <h5 class="card-title fw-bold text-dark mb-3">Mi Plantilla</h5>
                            <p class="text-muted small mb-4">Gestiona las tácticas y revisa los atributos de tu equipo.</p>
                            <a href="/formacion/<%= partida._id %>"" class="btn btn-outline-primary w-100 mb-2">Alineación y Tácticas</a>
                            <a href="/empleados/<%= partida._id %>" class="btn btn-outline-primary w-100">Empleados</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Modal de Carga -->
<div class="modal fade" id="modalCargaTiempo" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-primary shadow-lg">
            <div class="modal-body text-center p-5">
                <div class="spinner-border text-primary mb-3" style="width: 4rem; height: 4rem; border-width: 0.3em;" role="status">
                    <span class="visually-hidden">Cargando...</span>
                </div>
                <h4 class="fw-bold" id="textoCargaTiempo">Cargando...</h4>
                <p class="text-muted small mt-2 mb-0" id="subtextoCargaTiempo">Por favor, espera unos instantes.</p>
            </div>
        </div>
    </div>
</div>

<script>
    function mostrarCarga(titulo, subtitulo) {
        if (titulo) document.getElementById('textoCargaTiempo').innerText = titulo;
        if (subtitulo) document.getElementById('subtextoCargaTiempo').innerText = subtitulo;
        
        const modalElement = document.getElementById('modalCargaTiempo');
        const modalCarga = new bootstrap.Modal(modalElement);
        modalCarga.show();
    }
</script>
<style>
    .drop-shadow { filter: drop-shadow(0px 4px 6px rgba(0,0,0,0.5)); }
    .hover-card { transition: transform 0.2s; }
    .hover-card:hover { transform: translateY(-5px); }
</style>