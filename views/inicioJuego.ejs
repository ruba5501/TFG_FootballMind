<%- include('partials/head', {title: 'Centro de Mando - FootballMind'}) %>
<header>
  <%- include('partials/navbar') %>
</header>

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card bg-dark text-white shadow">
                <div class="card-body d-flex align-items-center justify-content-between p-4">
                    <div>
                        <h2 class="mb-1 fw-bold"><%= clubUsuario.nombre %></h2>
                        <p class="mb-0 text-light opacity-75">
                            <i class="bi bi-person-fill me-1"></i> Mánager: <%= user.username %> | Temporada Inicial
                        </p>
                    </div>
                    <div>
                        <img src="/img/escudos/<%= clubUsuario.escudo %>" alt="Escudo" width="90" class="drop-shadow">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="card shadow border-0 h-100">
                <div class="card-header bg-primary text-white text-center fw-bold py-3">
                    PRÓXIMO PARTIDO
                </div>
                <div class="card-body bg-light d-flex flex-column justify-content-center">
                    <% if (proximoPartido) { %>
                        <div class="mb-3">
                            <%- include('partials/proximoPartido', { partidos, clubUsuario }) %>
                        </div>
                        
                        <div class="d-grid mt-auto">
                            <a href="/jugar-partido/<%= proximoPartido._id %>" class="btn btn-success btn-lg fw-bold shadow-sm">
                                JUGAR PARTIDO
                            </a>
                        </div>
                    <% } else { %>
                        <div class="text-center p-4 text-muted">
                            <p class="mb-0">No hay partidos programados próximamente.</p>
                            <p class="small">Revisa el calendario o avanza de fecha.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="col-md-7 mb-4">
            <div class="row g-3">
                <div class="col-sm-6">
                    <div class="card shadow-sm border-0 h-100 hover-card">
                        <div class="card-body text-center p-4">
                            <h5 class="card-title fw-bold text-dark mb-3">Competiciones</h5>
                            <p class="text-muted small mb-4">Revisa la clasificación de liga y el avance en copa.</p>
                            <a href="/clasificacion/<%= partida._id %>" class="btn btn-outline-dark w-100 mb-2">Clasificación de Liga</a>
                            <a href="/calendario" class="btn btn-outline-dark w-100">Ver Calendario</a>
                        </div>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="card shadow-sm border-0 h-100 hover-card">
                        <div class="card-body text-center p-4">
                            <h5 class="card-title fw-bold text-dark mb-3">Mi Plantilla</h5>
                            <p class="text-muted small mb-4">Gestiona las tácticas y revisa los atributos de tu equipo.</p>
                            <a href="#" class="btn btn-outline-primary w-100 mb-2">Alineación y Tácticas</a>
                            <a href="#" class="btn btn-outline-primary w-100">Centro Médico</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .drop-shadow { filter: drop-shadow(0px 4px 6px rgba(0,0,0,0.5)); }
    .hover-card { transition: transform 0.2s; }
    .hover-card:hover { transform: translateY(-5px); }
</style>