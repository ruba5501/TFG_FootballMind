<%- include('partials/head', {title: 'Centro de Traspasos'}) %>
<%- include('partials/navbar') %>

<div class="container-fluid mt-3">
    <ul class="nav nav-tabs justify-content-center mb-3" id="traspasosTabs" role="tablist">
        <li class="nav-item">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-buscador">
                <i class="bi bi-search me-2"></i>Buscador de Jugadores
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-ojeadores">
                <i class="bi bi-geo-alt me-2"></i>Red de Ojeadores
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-listaObjetivos">
                <i class="bi bi-list-stars me-2"></i>Lista de Objetivos
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="tab-buscador">
            <div class="card shadow-sm mb-4">
                <div class="card-body bg-dark text-white rounded">
                    <form action="/traspasos/buscar/<%= partida._id %>" method="GET" class="row g-3" novalidate>
                        <% if (typeof errorFiltros !== 'undefined' && errorFiltros) { %>
                            <small class="text-danger d-block mt-1"><%= errorFiltros %></small>
                        <% } %>
                        <div class="col-md-3">
                            <label class="small">Nombre / Equipo</label>
                            <input type="text" name="query" class="form-control form-control-sm" placeholder="Buscar...">
                        </div>
                        <div class="col-md-2">
                            <label class="small">Liga</label>
                            <select name="liga" id="liga" class="form-select form-select-sm">
                                <option value="">Todas las ligas</option>
                                <% ligas.forEach(liga => { %>
                                    <option value="<%= liga._id %>"><%= liga.nombre %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="col-md-2">
                            <label class="small">Club</label>
                            <input type="text" 
                                id="club" 
                                class="form-control form-control-sm" 
                                list="lista-clubes" 
                                placeholder="Escribe o selecciona">
                            
                            <datalist id="lista-clubes">
                                <% clubes.forEach(club => { %>
                                    <option value="<%= club.nombre %>" data-id="<%= club._id %>" data-competiciones="<%= club.competiciones %>"></option>
                                <% }) %>
                            </datalist>
                            <input type="hidden" name="clubId" id="club-id-hidden">
                        </div>

                        <div class="col-md-2">
                            <label class="small">Posición</label>
                            <select name="posicion" class="form-select form-select-sm">
                                <option value="">Todas</option>
                                <option value="POR">POR</option>
                                <option value="DFC">DFC</option>
                                <option value="LI">LI</option>
                                <option value="LD">LD</option>
                                <option value="MCD">MCD</option>
                                <option value="MC">MC</option>
                                <option value="MI">MI</option>
                                <option value="MD">MD</option>
                                <option value="MCO">MCO</option>
                                <option value="EI">EI</option>
                                <option value="ED">ED</option>
                                <option value="SD">SD</option>
                                <option value="DC">DC</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="small">Estado</label>
                            <select name="estado" class="form-select form-select-sm">
                                <option value="">Cualquiera</option>
                                <option value="transferible">Transferible</option>
                                <option value="cedible">Cedible</option>
                                <option value="libre">Sin Equipo</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="small">Edad (Min - Max)</label>
                            <div class="input-group input-group-sm">
                                <input type="number" name="edadMin" class="form-control" placeholder="Ej: 15">
                                <input type="number" name="edadMax" class="form-control" placeholder="Ej: 40">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="small">Valor Mercado (Min - Max)</label>
                            <div class="input-group input-group-sm">
                                <input type="number" name="valorMin" class="form-control" placeholder="Ej: 200000">
                                <input type="number" name="valorMax" class="form-control" placeholder="Ej: 150000000">
                            </div>
                        </div>
                        
                        <div class="col-12 text-center">
                            <button class="btn btn-sm btn-outline-light w-100" type="button" data-bs-toggle="collapse" data-bs-target="#filtrosAvanzados">
                                Filtros de Atributos ▼
                            </button>
                        </div>

                        <div class="collapse col-12" id="filtrosAvanzados">
                            <div class="row g-2 mt-2 border-top pt-3">
                                <strong class="text-uppercase">tecnica</strong>
                                <div class="col-md-2">
                                    <label class="small">Regate (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="regMin" class="form-control" placeholder="0">
                                        <input type="number" name="regMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Control Balón (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="contBalMin" class="form-control" placeholder="0">
                                        <input type="number" name="contBalMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Desmarques (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="desMin" class="form-control" placeholder="0">
                                        <input type="number" name="desMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <strong class="text-uppercase">tiro</strong>
                                <div class="col-md-2">
                                    <label class="small">Definición (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="defMin" class="form-control" placeholder="0">
                                        <input type="number" name="defMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Potencia Tiro (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="potTirMin" class="form-control" placeholder="0">
                                        <input type="number" name="potTirMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Tiro Lejano (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="tirLejMin" class="form-control" placeholder="0">
                                        <input type="number" name="tirLejMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Faltas (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="falMin" class="form-control" placeholder="0">
                                        <input type="number" name="falMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Penaltis (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="penMin" class="form-control" placeholder="0">
                                        <input type="number" name="penMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Remate cabeza (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="remCaMin" class="form-control" placeholder="0">
                                        <input type="number" name="remCaMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <strong class="text-uppercase">pase</strong>
                                <div class="col-md-2">
                                    <label class="small">Pase corto (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="pasCorMin" class="form-control" placeholder="0">
                                        <input type="number" name="pasCorMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Pase largo (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="pasLarMin" class="form-control" placeholder="0">
                                        <input type="number" name="pasLarMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Vsión (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="visMin" class="form-control" placeholder="0">
                                        <input type="number" name="visMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Centros (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="cenMin" class="form-control" placeholder="0">
                                        <input type="number" name="cenMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <strong class="text-uppercase">defensa</strong>
                                <div class="col-md-2">
                                    <label class="small">Marcaje (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="marMin" class="form-control" placeholder="0">
                                        <input type="number" name="marMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Entradas (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="entMin" class="form-control" placeholder="0">
                                        <input type="number" name="entMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Intercepciones (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="intMin" class="form-control" placeholder="0">
                                        <input type="number" name="intMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Despejes (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="despMin" class="form-control" placeholder="0">
                                        <input type="number" name="despMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Duelos Aereos (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="dueArMin" class="form-control" placeholder="0">
                                        <input type="number" name="dueArMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Colocación (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="colMin" class="form-control" placeholder="0">
                                        <input type="number" name="colMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <strong class="text-uppercase">físico</strong>
                                <div class="col-md-2">
                                    <label class="small">Velocidad (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="velMin" class="form-control" placeholder="0">
                                        <input type="number" name="velMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Aceleración (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="aceMin" class="form-control" placeholder="0">
                                        <input type="number" name="aceMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Agilidad (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="agiMin" class="form-control" placeholder="0">
                                        <input type="number" name="agiMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Fuerza (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="fueMin" class="form-control" placeholder="0">
                                        <input type="number" name="fueMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Resistencia (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="resMin" class="form-control" placeholder="0">
                                        <input type="number" name="resMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Equilibrio (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="equiMin" class="form-control" placeholder="0">
                                        <input type="number" name="equiMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Salto (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="saltMin" class="form-control" placeholder="0">
                                        <input type="number" name="saltMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <strong class="text-uppercase">mental</strong>
                                <div class="col-md-2">
                                    <label class="small">Concentración (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="concMin" class="form-control" placeholder="0">
                                        <input type="number" name="concMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Liderazgo (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="lidMin" class="form-control" placeholder="0">
                                        <input type="number" name="lidMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Agresividad (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="agreMin" class="form-control" placeholder="0">
                                        <input type="number" name="agreMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Motivación (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="motMin" class="form-control" placeholder="0">
                                        <input type="number" name="motMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Compostura Bajo Presión (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="compBaPreMin" class="form-control" placeholder="0">
                                        <input type="number" name="compBaPreMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <strong class="text-uppercase">portero</strong>
                                <div class="col-md-2">
                                    <label class="small">Reflejos (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="refMin" class="form-control" placeholder="0">
                                        <input type="number" name="refMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Paradas (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="paraMin" class="form-control" placeholder="0">
                                        <input type="number" name="paraMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Estirada (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="estMin" class="form-control" placeholder="0">
                                        <input type="number" name="estMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Juego Aereo (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="jueArMin" class="form-control" placeholder="0">
                                        <input type="number" name="jueArMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Uno contra uno (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="unoVSunoMin" class="form-control" placeholder="0">
                                        <input type="number" name="unoVSunoMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Blocaje (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="blocMin" class="form-control" placeholder="0">
                                        <input type="number" name="blocMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Saque (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="saqMin" class="form-control" placeholder="0">
                                        <input type="number" name="saqMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Comunicación (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="comuMin" class="form-control" placeholder="0">
                                        <input type="number" name="comuMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">Penaltis (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="penalMin" class="form-control" placeholder="0">
                                        <input type="number" name="penalMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 text-end">
                            <button type="submit" class="btn btn-primary btn-sm px-4">Realizar Búsqueda</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-ojeadores">
            <div class="row row-cols-1 row-cols-md-3 g-4">
                 <% ojeadores.forEach(ojeador => { %>
                    <%- include('partials/redOjeadores', { ojeador: ojeador, contexto: 'traspasos' }) %>
                    <% }) %>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-listaObjetivos">
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
                <% listaObjetivos.forEach(jugador => { %>
                    <div class="col" id="card-objetivo-<%= jugador._id %>">
                        <div class="card h-100 bg-dark text-white border-secondary shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="card-title text-info mb-0"><%= jugador.nombre %></h5>
                                    <span class="badge bg-light text-dark"><%= jugador.posicionPrincipal %></span>
                                </div>

                                <div class="small mb-3">
                                    <p class="text pt-3">
                                        Media: <%= jugador.valoracion %> | Potencial: <%= jugador.potencial %> | 
                                        <%= jugador.nacionalidad %> 
                                        <img src="/img/banderas/<%= jugador.nacionalidad %>.png"
                                            alt="<%= jugador.nacionalidad %>" 
                                            class="ms-1 shadow-sm" 
                                            style="height: 14px; width: auto; vertical-align: middle; border-radius: 2px;"
                                        > 
                                        | <%= jugador.edad %> años | <%= jugador.altura %>cm | <%= jugador.peso %>kg
                                    </p>
                                    <div class="mt-2 p-2 bg-black bg-opacity-25 rounded border border-secondary">
                                        <strong>Club:</strong> 
                                        <span class="<%= jugador.clubActual ? 'text-white' : 'text-success fw-bold' %>">
                                            <% if (jugador.clubActual) { %>
                                                <%= jugador.clubActual.nombre %>
                                                <img src="/img/escudos/<%= jugador.clubActual.escudo %>" 
                                                    alt=""
                                                    class="me-1 shadow-sm"
                                                    style="height: 18px; width: auto; vertical-align: middle; border-radius: 2px;"
                                                    onerror="this.style.display='none';"> 
                                                
                                            <% } else { %>
                                                <i class="bi bi-person-x me-1"></i> Agente Libre
                                            <% } %>
                                        </span><br>
                                        <strong>Otras pos.:</strong> <%= jugador.posicionesSecundarias.join(', ') || '---' %>
                                    </div>
                                </div>

                                <div class="d-grid gap-2">
                                    <div class="btn-group w-100">
                                        <button class="btn btn-sm btn-outline-info" onclick="verAtributos('<%= jugador._id %>')">
                                            <i class="bi bi-bar-chart-fill me-1"></i> Atributos
                                        </button>
                                        
                                        <button class="btn btn-sm btn-outline-danger" onclick="gestionarListaObjetivos('<%= jugador._id %>', 'quitar')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>

                                    <% if (!jugador.clubActual || jugador.clubActual.nombre === 'Libre' || jugador.acuerdoConClub) { %>
                                        <button class="btn btn-success" onclick="iniciarNegociacionContrato('<%= jugador._id %>')">
                                            <i class="bi bi-file-earmark-person me-1"></i> Negociar Contrato
                                        </button>
                                    <% } else { %>
                                        <button class="btn btn-primary" onclick="negociarTraspasoClub('<%= jugador._id %>')">
                                            <i class="bi bi-chat-dots me-1"></i> Contactar para Fichar
                                        </button>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>
</div>

<%- include('partials/modal_atributos') %>
<script src="/js/plantilla.js"></script>
<script src="/js/buscadorTraspasos.js"></script>