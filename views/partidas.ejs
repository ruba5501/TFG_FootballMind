<%- include('partials/head', {title: 'Cargar partida'}) %>
<body>
  <h1>Tus partidas</h1>

  <a href="/partidas/nueva">Nueva Partida</a>

  <ul>
    <% partidas.forEach(p => { %>
      <li>
        <strong><%= p.nombrePartida %></strong> - <%= p.clubSeleccionado %>
        (Última actualización: <%= p.ultimaActualizacion.toLocaleDateString() %>)
        <a href="/partidas/cargarPartida/<%= p._id %>">Continuar</a>
        <form method="POST" action="/partidas/eliminar/<%= p._id %>" style="display:inline;">
          <button type="submit">Eliminar</button>
        </form>
      </li>
    <% }) %>
  </ul>
</body>
</html>
