<%- include('partials/head', {title: 'Gestión de Empleados'}) %>
<%- include('partials/navbar') %>
<div class="container mt-4">
    <div class="card mb-4 shadow">
        <div class="card-header bg-primary text-white">Filtros de Búsqueda</div>
        <div class="card-body">
            <form action="/empleados/<%= partida._id %>" method="GET" class="row g-3">
                <div class="col-md-3"><input type="text" name="nombre" class="form-control" placeholder="Nombre..."></div>
                <div class="col-md-3"><input type="text" name="club" class="form-control" placeholder="Club..."></div>
                <div class="col-md-2"><select name="estado" class="form-control"><option value="">Todos</option><option value="libre">Libre</option></select></div>
                <div class="col-md-2"><input type="number" name="minSueldo" class="form-control" placeholder="Min Sueldo"></div>
                <div class="col-md-2"><input type="number" name="maxSueldo" class="form-control" placeholder="Max Sueldo"></div>
                <div class="col-12 text-center">
                    <button type="button" class="btn btn-sm btn-link" data-bs-toggle="collapse" data-bs-target="#filtrosAtributos">Más filtros (Atributos) ▼</button>
                </div>
                <div class="collapse" id="filtrosAtributos">
                    <div class="row g-2 mt-2">
                        <div class="col-md-2"><input type="number" name="minFisico" class="form-control" placeholder="Min Físico"></div>
                        </div>
                </div>
                <div class="col-12 text-end">
                    <button type="submit" class="btn btn-success">Filtrar</button>
                    <a href="/empleados/<%= partida._id %>" class="btn btn-secondary">Limpiar</a>
                </div>
            </form>
        </div>
    </div>

    <div id="contenedorEmpleados" class="accordion" id="accordionEmpleados">
        <% Object.entries(grupos).forEach(([titulo, tipos], index) => { %>
            <div class="accordion-item mb-3 border-0 shadow-sm">
                <h2 class="accordion-header">
                    <button class="accordion-button <%= index !== 0 ? 'collapsed' : '' %>" type="button" data-bs-toggle="collapse" data-bs-target="#collapse<%= index %>">
                        <strong class="text-uppercase"><%= titulo %></strong>
                    </button>
                </h2>
                <div id="collapse<%= index %>" class="accordion-collapse collapse <%= index === 0 ? 'show' : '' %>" data-bs-parent="#accordionEmpleados">
                    <div class="accordion-body bg-white">
                        <div class="row">
                            <% empleados.filter(e => tipos.includes(e.tipo)).forEach(emp => { %>
                                <div class="col-md-4 col-lg-3">
                                    <div class="card mb-3 border-start border-primary border-4">
                                        <div class="card-body">
                                            <h6 class="fw-bold"><%= emp.nombre %></h6>
                                            <small class="text-muted"><%= emp.tipo %></small>
                                            <div class="mt-2">
                                                <button class="btn btn-outline-info btn-sm" onclick="verAtributos('<%= emp._id %>')">
                                                    Detalles
                                                </button>
                                                <button class="btn btn-outline-danger btn-sm" onclick="confirmarDespido('<%= emp._id %>')">
                                                    Despedir
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>

<div class="modal fade" id="modalAtributos" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5>Atributos del Empleado</h5></div>
            <div class="modal-body" id="modalBodyAtributos">
                </div>
        </div>
    </div>
</div>

<script>
document.getElementById('formBusqueda').addEventListener('submit', async (e) => {
    e.preventDefault();
    const formData = new URLSearchParams(new FormData(e.target));
    
    const res = await fetch('/buscar?' + formData.toString());
    const empleados = await res.json();
});
</script>