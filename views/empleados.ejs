<%- include('partials/head', {title: 'Gestión de Empleados'}) %>
<%- include('partials/navbar') %>
<div class="container-fluid mt-3">
    <ul class="nav nav-pills justify-content-center mb-3" id="traspasosTabs" role="tablist">
        <li class="nav-item">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-listaEmpleados">
                <i class="bi bi-geo-alt me-2"></i>Lista de Empleados
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-buscadorEmpleados">
                <i class="bi bi-search me-2"></i>Buscador de Empleados
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-listaObjetivos">
                <i class="bi bi-list-stars me-2"></i>Lista de Objetivos
            </button>
        </li>
    </ul>
    <div class="tab-content">
        <div class="tab-pane fade show active" id="tab-listaEmpleados">
            <div id="contenedorEmpleados" class="accordion" id="accordionEmpleados">
                <% Object.entries(grupos).forEach(([titulo, tipos], index) => { %>
                    <div class="accordion-item mb-3 border-0 shadow-sm">
                        <h2 class="accordion-header">
                            <button class="accordion-button <%= index !== 0 ? 'collapsed' : '' %>" type="button" data-bs-toggle="collapse" data-bs-target="#collapse<%= index %>">
                                <strong class="text-uppercase"><%= titulo %></strong>
                            </button>
                        </h2>
                        <div id="collapse<%= index %>" class="accordion-collapse collapse <%= index === 0 ? 'show' : '' %>" data-bs-parent="#accordionEmpleados">
                            <div class="accordion-body bg-white">
                                <div class="row">
                                    <% empleados.filter(e => tipos.includes(e.tipo)).forEach(emp => { %>
                                        <div class="col-md-4 col-lg-3">
                                            <div class="card mb-3 border-start border-primary border-4">
                                                <div class="card-body">
                                                    <h6 class="fw-bold"><%= emp.nombre %></h6>
                                                    <small class="text-muted"><%= emp.tipo %></small>
                                                    <div class="mt-2">
                                                        <button class="btn btn-outline-info btn-sm" onclick="verAtributosEmpleado('<%= emp._id %>')">
                                                            Detalles
                                                        </button>
                                                        <button class="btn btn-outline-info btn-sm" onclick="NegociarContrato('<%= emp._id %>')">
                                                            Renovar
                                                        </button>
                                                        <button class="btn btn-outline-danger btn-sm" onclick="confirmarDespido('<%= emp._id %>')">
                                                            Despedir
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    <% }) %>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
        <div class="tab-pane fade" id="tab-buscadorEmpleados">
            <div class="card shadow-sm mb-4">
                <div class="card-body bg-dark text-white rounded">
                    <form action="/empleados/buscar/<%= partida._id %>" method="GET" class="row g-3" novalidate>
                        <% if (typeof errorFiltros !== 'undefined' && errorFiltros) { %>
                            <small class="text-danger d-block mt-1"><%= errorFiltros %></small>
                        <% } %>
                        <div class="col-md-3">
                            <label class="small">Nombre</label>
                            <input type="text" name="query" class="form-control form-control-sm" placeholder="Buscar...">
                        </div>
                        <div class="col-md-2">
                            <label class="small">Liga</label>
                            <select name="liga" id="liga" class="form-select form-select-sm">
                                <option value="">Todas las ligas</option>
                                <% ligas.forEach(liga => { %>
                                    <option value="<%= liga._id %>"><%= liga.nombre %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="col-md-2">
                            <label class="small">Club</label>
                            <input type="text" 
                                id="club" 
                                class="form-control form-control-sm" 
                                list="lista-clubes" 
                                placeholder="Escribe o selecciona">
                            
                            <datalist id="lista-clubes">
                                <% clubes.forEach(club => { %>
                                    <option value="<%= club.nombre %>" data-id="<%= club._id %>" data-competiciones="<%= club.competiciones %>"></option>
                                <% }) %>
                            </datalist>
                            <input type="hidden" name="clubId" id="club-id-hidden">
                        </div>

                        <div class="col-md-2">
                            <label class="small">Cargo</label>
                            <select name="cargo" class="form-select form-select-sm">
                                <option value="">Todas</option>
                                <option value="preparadorFisico">preparador Físico</option>
                                <option value="preparadorTecnico">preparador Técnico</option>
                                <option value="preparadorTactico">preparador Táctico</option>
                                <option value="preparadorPorteros">preparador Porteros</option>
                                <option value="psicologo">psicólogo</option>
                                <option value="medico">médico</option>
                                <option value="fisio">fisio</option>
                                <option value="ojeador">ojeador</option>
                                <option value="ojeadorCantera">ojeador Cantera</option>
                                <option value="entrenador">entrenador</option>
                                <option value="segundoEntrenador">segundo Entrenador</option>
                                <option value="entrenadorCantera">entrenador Cantera</option>
                            </select>
                        </div>

                        <div class="col-md-2">
                            <label class="small">Estado</label>
                            <select name="estado" class="form-select form-select-sm">
                                <option value="">Cualquiera</option>
                                <option value="transferible">Con Equipo</option>
                                <option value="libre">Sin Equipo</option>
                            </select>
                        </div>

                        <div class="col-md-3">
                            <label class="small">Edad (Min - Max)</label>
                            <div class="input-group input-group-sm">
                                <input type="number" name="edadMin" class="form-control" placeholder="Ej: 15">
                                <input type="number" name="edadMax" class="form-control" placeholder="Ej: 40">
                            </div>
                        </div>

                        <div class="col-12 text-center">
                            <button class="btn btn-sm btn-outline-light w-100" type="button" data-bs-toggle="collapse" data-bs-target="#filtrosAvanzados">
                                Filtros de Atributos ▼
                            </button>
                        </div>

                        <div class="collapse col-12" id="filtrosAvanzados">
                            <div class="row g-2 mt-2 border-top pt-3">
                                <div class="col-md-2">
                                    <label class="small">nivelFisico (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="nivFisMin" class="form-control" placeholder="0">
                                        <input type="number" name="nivFisMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">nivelTecnico (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="nivTecMin" class="form-control" placeholder="0">
                                        <input type="number" name="nivTecMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">nivelTactico (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="nivTacMin" class="form-control" placeholder="0">
                                        <input type="number" name="nivTacMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">nivelPortero (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="nivPorMin" class="form-control" placeholder="0">
                                        <input type="number" name="nivPorMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">nivelPsicologico (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="nivPsiMin" class="form-control" placeholder="0">
                                        <input type="number" name="nivPsiMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">nivelMedico (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="nivMedMin" class="form-control" placeholder="0">
                                        <input type="number" name="nivMedMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">nivelRecuperacion (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="nivRecuMin" class="form-control" placeholder="0">
                                        <input type="number" name="nivRecuMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">nivelPrevencionLesiones (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="nivPreLesMin" class="form-control" placeholder="0">
                                        <input type="number" name="nivPreLesMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">nivelDeteccion (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="nivDetMin" class="form-control" placeholder="0">
                                        <input type="number" name="nivDetMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">nivelCantera (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="nivCanMin" class="form-control" placeholder="0">
                                        <input type="number" name="nivCanMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">motivacion (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="motMin" class="form-control" placeholder="0">
                                        <input type="number" name="motMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">RedesarrolloJovenesgate (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="desJovMin" class="form-control" placeholder="0">
                                        <input type="number" name="desJovMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">reputacion (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="repuMin" class="form-control" placeholder="0">
                                        <input type="number" name="repuMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <label class="small">experiencia (Min - Max)</label>
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="expeMin" class="form-control" placeholder="0">
                                        <input type="number" name="expeMax" class="form-control" placeholder="99">
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12 text-end">
                            <button type="submit" class="btn btn-primary btn-sm px-4">Realizar Búsqueda</button>
                            <a href="/empleados/<%= partida._id %>" class="btn btn-secondary">Limpiar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-listaObjetivos">
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
                <% listaObjetivos.forEach(empleado => { %>
                    <div class="col" id="card-objetivo-<%= empleado._id %>">
                        <div class="card h-100 bg-dark text-white border-secondary shadow-sm">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="card-title text-info mb-0"><%= empleado.nombre %></h5>
                                    <span class="badge bg-light text-dark"><%= empleado.tipo %></span>
                                </div>

                                <div class="small mb-3">
                                    <div class="mt-2 p-2 bg-black bg-opacity-25 rounded border border-secondary">
                                        <p class="text pt-3">
                                            <%= empleado.nacionalidad %> 
                                            <img src="/img/banderas/<%= empleado.nacionalidad %>.png"
                                                alt="<%= empleado.nacionalidad %>" 
                                                class="ms-1 shadow-sm" 
                                                style="height: 14px; width: auto; vertical-align: middle; border-radius: 2px;"
                                            > 
                                            | <%= empleado.edad %> años
                                        </p>
                                        <strong>Club:</strong> 
                                        <span class="<%= empleado.clubActual ? 'text-white' : 'text-success fw-bold' %>">
                                            <% if (empleado.clubActual) { %>
                                                <%= empleado.clubActual.nombre %>
                                                <img src="/img/escudos/<%= empleado.clubActual.escudo %>" 
                                                    alt=""
                                                    class="me-1 shadow-sm"
                                                    style="height: 18px; width: auto; vertical-align: middle; border-radius: 2px;"
                                                    onerror="this.style.display='none';"> 
                                                
                                            <% } else { %>
                                                <i class="bi bi-person-x me-1"></i> Agente Libre
                                            <% } %>
                                        </span><br>
                                    </div>
                                </div>

                                <div class="d-grid gap-2">
                                    <div class="btn-group w-100">
                                        <button class="btn btn-sm btn-outline-info" onclick="verAtributosEmpleado('<%= empleado._id %>')">
                                            <i class="bi bi-bar-chart-fill me-1"></i> Atributos
                                        </button>
                                        
                                        <button class="btn btn-sm btn-outline-danger" onclick="gestionarListaObjetivos('<%= empleado._id %>', 'quitar', 'empleado')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                    <button class="btn btn-success" onclick="NegociarContrato('<%= empleado._id %>')">
                                        Negociar Contrato
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>
    </div>
</div>

<%- include('partials/modal_atributos') %>
<%- include('partials/modal_traspasos') %>
<%- include('partials/modal_contratos') %>

<script src="/js/plantilla.js"></script>
<script src="/js/buscadorTraspasos.js"></script>