<%- include('partials/head', {title: 'Centro de Negociaciones'}) %>
<%- include('partials/navbar') %>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-handshake text-primary"></i> Centro de Negociaciones</h2>
    </div>

    <ul class="nav nav-tabs mb-4" id="negociacionesTab" role="tablist">
        <li class="nav-item">
            <button class="nav-link active" id="enviadas-tab" data-bs-toggle="tab" data-bs-target="#enviadas" type="button">
                Ofertas Enviadas <span class="badge bg-primary ms-1"><%= ofertasEnviadas.length %></span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" id="recibidas-tab" data-bs-toggle="tab" data-bs-target="#recibidas" type="button">
                Ofertas Recibidas <span class="badge bg-danger ms-1"><%= ofertasRecibidas.length %></span>
            </button>
        </li>
    </ul>

    <div class="tab-content" id="negociacionesTabContent">
        
        <div class="tab-pane fade show active" id="enviadas" role="tabpanel">
            <% if (ofertasEnviadas.length === 0) { %>
                <div class="text-center p-5 bg-light rounded border">
                    <i class="bi bi-folder-x fs-1 text-muted"></i>
                    <p class="text-muted mt-2">No tienes negociaciones en este momento.</p>
                </div>
            <% } else { %>
                <div class="table-responsive bg-white shadow-sm rounded border">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Objetivo</th>
                                <th>Tipo</th>
                                <th>Club Propietario</th>
                                <th>Estado Operación</th>
                                <th>Estado Contrato</th>
                                <th class="text-center">Última Oferta</th>
                                <th class="text-center">Última Oferta Contrato</th>
                                <th class="text-center">Última Contraoferta</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% ofertasEnviadas.forEach(neg => { %>
                                <tr>
                                    <td>
                                        <div class="fw-bold"><%= neg.objetivoId.nombre %></div>
                                        <small class="text-muted">• Media <%= neg.objetivoId.valoracion %> • Posicion Principal <%= neg.objetivoId.posicionPrincipal %></small>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill bg-info text-dark">
                                            <%= neg.tipoObjetivo === 'Jugador' ? 'JUGADOR' : 'EMPLEADO' %>
                                        </span>
                                        <div class="small text-muted text-uppercase" style="font-size: 0.7rem;"><%= neg.tipo %></div>
                                    </td>
                                    <td>
                                        <% if (neg.clubReceptor) { %>
                                            <div class="d-flex align-items-center">
                                                <% if (neg.clubReceptor.escudo) { %>
                                                    <img src="/img/escudos/<%= neg.clubReceptor.escudo %>" width="20" class="me-2">
                                                <% } %>
                                                <%= neg.clubReceptor.nombre %>
                                            </div>
                                        <% } else { %>
                                            <span class="text-muted italic">Agente Libre</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% 
                                            let badgeTraspaso = 'bg-warning text-dark';
                                            if (neg.estadoTraspaso === 'aceptado') badgeTraspaso = 'bg-success';
                                            if (neg.estadoTraspaso === 'rechazado') badgeTraspaso = 'bg-danger';
                                        %>
                                        <span class="badge <%= badgeTraspaso %>">
                                            <%= neg.estadoTraspaso.toUpperCase().replace('_', ' ') %>
                                        </span>
                                    </td>
                                    <td>
                                        <% 
                                            let badgeCont = 'border text-muted';
                                            if (neg.estadoContrato === 'aceptado') badgeCont = 'bg-success text-white';
                                            if (neg.estadoContrato === 'rechazado') badgeCont = 'bg-danger text-white';
                                            if (neg.estadoContrato === 'negociando') badgeCont = 'bg-warning text-dark';
                                        %>
                                        <span class="badge <%= badgeCont %>">
                                            <%= neg.estadoContrato.toUpperCase().replace('_', ' ') %>
                                        </span>
                                    </td>
                                    <td>
                                        <div class="small fw-bold text-cyan">
                                            <% if (neg.tipoOferta === 'traspaso') { %>
                                                <div><%= neg.ofertaTraspaso.toLocaleString() %> €</div>
                                                
                                                <% if (neg.porcentajeFuturaVenta > 0) { %>
                                                    <div class="text-muted small">+ <%= neg.porcentajeFuturaVenta %>% futura venta</div>
                                                <% } %>
                                                <% if (neg.precioRecompra > 0) { %>
                                                    <div class="text-muted small">+ <%= neg.precioRecompra.toLocaleString() %> € recompra</div>
                                                <% } %>

                                            <% } else { %>
                                                <div><%= neg.ofertaTraspaso %>% sueldo</div>
                                                
                                                <% if (neg.clausulaCompra > 0) { %>
                                                    <div class="text-muted small">+ <%= neg.clausulaCompra.toLocaleString() %> € opción compra</div>
                                                <% } %>
                                            <% } %>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="small fw-bold text-cyan">
                                            <% if (neg.ofertaSueldo > 0) { %>
                                                <div><%= neg.ofertaSueldo.toLocaleString() %> €/año</div>
                                                <div><%= neg.ofertaAnios %> años</div>
                                                <div><%= neg.rolPrometido %></div>
                                                
                                                <% if (neg.PrimaContrato > 0) { %>
                                                    <div class="text-muted small">+ <%= neg.PrimaContrato.toLocaleString() %> € de prima</div>
                                                <% } %>
                                                <% if (neg.clausulaRescision > 0) { %>
                                                    <div class="text-muted small">+ <%= neg.clausulaRescision.toLocaleString() %> € de cláusula</div>
                                                <% } %>

                                            <% } else { %>
                                                <div class="text-muted small">Sueldo por negociar%></div>
                                            <% } %>
                                            
                                        </div>
                                    </td>
                                    <td>
                                        <% if (neg.estadoContrato === 'no_iniciado') { %>
                                            <div class="small fw-bold text-primary">
                                                <% if (neg.tipoOferta === 'traspaso') { %>
                                                    
                                                    <% if (neg.estadoTraspaso === 'negociando' && !neg.basicoAceptado) { %>
                                                        <div class="fs-6"><%= neg.contraofertaTraspaso.toLocaleString() %> €</div>
                                                    <% } else if (neg.basicoAceptado) { %>
                                                        <% if (neg.precioRecompra > 0) { %>
                                                            <div class="text-success small"><i class="bi bi-check-circle"></i> <%= neg.ofertaTraspaso.toLocaleString() %> €</div>
                                                            <% if (neg.porcentajeFuturaVenta > 0) { %>
                                                                <div class="text-success small"><i class="bi bi-check-circle"></i>+ <%= neg.porcentajeFuturaVenta.toLocaleString() %> % futura venta</div>
                                                            <% } %>
                                                            <div class="fs-6">+ <%= neg.contraofertaTraspaso.toLocaleString() %> € recompra</div>
                                                        <% } 
                                                        else { %>
                                                            <div class="fs-6"> <%= neg.contraofertaTraspaso.toLocaleString() %> €</div>
                                                            <% if (neg.porcentajeFuturaVenta > 0) { %>
                                                                <div class="fs-6">+ <%= neg.porcentajeFuturaVenta.toLocaleString() %> % futura venta</div>
                                                            <% } %>
                                                        <% } %>
                                                    <% } %>

                                                <% } else { %>
                                                    
                                                    <% if (neg.estadoTraspaso === 'negociando' && !neg.basicoAceptado) { %>
                                                        <div class="fs-6"><%= neg.ofertaTraspaso %>% sueldo</div>
                                                    <% } else if (neg.basicoAceptado) { %>                                                    
                                                        <% if (neg.clausulaCompra > 0) { %>
                                                            <div class="text-success small"><i class="bi bi-check-circle"></i> <%= neg.ofertaTraspaso %>%</div>
                                                            <div class="fs-6">+ <%= neg.contraofertaTraspaso.toLocaleString() %> € compra</div>
                                                        <% }
                                                        else { %>
                                                            <div class="fs-6"> <%= neg.contraofertaTraspaso.toLocaleString() %> % sueldo</div>
                                                        <% } %>
                                                    <% } %>
                                                <% } %>
                                            </div>
                                        <% } else { %>
                                            <div class="small fw-bold text-primary">
                                                <% if (neg.estadoContrato === 'negociando' && !neg.basicoContratoAceptado) { %>
                                                    <% if (neg.contraofertaSueldo != null) { %>
                                                        <div class="fs-6"><%= neg.contraofertaSueldo.toLocaleString() %> €</div>
                                                    <% } %>
                                                    <% if (neg.contraofertaAños != null) { %>
                                                        <div class="fs-6"> <%= neg.contraofertaAños %> años máximo</div>
                                                    <% } %>  
                                                    <% if (neg.contraofertaRol != '') { %>
                                                        <div class="fs-6"> <%= neg.contraofertaRol %></div>
                                                    <% } %>  
                                                <% } else if (neg.basicoContratoAceptado) { %>
                                                    <% if (neg.contraofertaPrima > 0) { %>
                                                        <div class="text-success small"><i class="bi bi-check-circle"></i> <%= neg.ofertaSueldo.toLocaleString() %> €/año</div>
                                                        <div class="text-success small"><i class="bi bi-check-circle"></i> <%= neg.ofertaAnios %> años máximo</div>
                                                        <div class="text-success small"><i class="bi bi-check-circle"></i> <%= neg.rolPrometido %></div>
                                                        <div class="fs-6">+ <%= neg.contraofertaPrima.toLocaleString() %> € de prima</div>
                                                    <% } 
                                                    else { %>
                                                        <% if (neg.contraofertaSueldo != null) { %>
                                                            <div class="fs-6"><%= neg.contraofertaSueldo.toLocaleString() %> €</div>
                                                        <% } %>
                                                        <% if (neg.contraofertaAños != null) { %>
                                                            <div class="fs-6"> <%= neg.contraofertaAños %> años máximo</div>
                                                        <% } %>  
                                                        <% if (neg.contraofertaRol != '') { %>
                                                            <div class="fs-6"> <%= neg.contraofertaRol %></div>
                                                        <% } %>  
                                                    <% } %>
                                                <% } %>
                                            </div>
                                        <% } %>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-grid gap-1">
                                            <% if (neg.estadoTraspaso === 'aceptado') { %>
                                                <% if (neg.tipoOferta != 'cesion') { %>
                                                    <% if (neg.estadoContrato === 'no_iniciado') { %>
                                                        <button onclick="NegociarContrato(
                                                            '<%= neg.objetivoId._id %>', 
                                                            '<%= neg.ofertaSueldo || null %>', 
                                                            '<%= neg.contraofertaSueldo || null %>',
                                                            '<%= neg.ofertaAnios || null %>',
                                                            '<%= neg.rolPrometido %>',
                                                            '<%= neg.clausulaRescision || null %>',
                                                            '<%= neg.PrimaContrato || null %>'
                                                            )" class="btn btn-sm btn-success">
                                                            Negociar Contrato
                                                        </button>
                                                        <button onclick="finalizarNegociacion('<%= neg._id %>')" class="btn btn-sm btn-outline-danger">
                                                            finalizar
                                                        </button>
                                                    <% } else if(neg.estadoContrato === 'negociando'){ %>
                                                        <button onclick="NegociarContrato(
                                                            '<%= neg.objetivoId._id %>', 
                                                            '<%= neg.ofertaSueldo || null %>', 
                                                            '<%= neg.contraofertaSueldo || null %>',
                                                            '<%= neg.contraofertaAños || null %>',
                                                            '<%= neg.contraofertaRol %>',
                                                            '<%= neg.contraofertaPrima || null %>',
                                                            '<%= neg.ofertaAnios || null %>',
                                                            '<%= neg.rolPrometido %>',
                                                            '<%= neg.clausulaRescision || null %>',
                                                            '<%= neg.PrimaContrato || null %>'
                                                            )" class="btn btn-sm btn-primary">
                                                            Mejorar oferta Contrato
                                                        </button>
                                                        <button onclick="finalizarNegociacion('<%= neg._id %>')" class="btn btn-sm btn-outline-danger">
                                                            finalizar
                                                        </button>
                                                    <% } else { %>
                                                        <% if (neg.estadoContrato === 'aceptado') { %>
                                                            <button class="btn btn-sm btn-outline-secondary" disabled>Fichado</button>
                                                        <% } %>
                                                        <button onclick="borrarNegociacion('<%= neg._id %>')" class="btn btn-sm btn-outline-secondary">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    <% } %>
                                                <% } else  { %>
                                                    <button class="btn btn-sm btn-outline-secondary" disabled>Fichado</button>
                                                    <button onclick="borrarNegociacion('<%= neg._id %>')" class="btn btn-sm btn-outline-secondary">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                <% } %>
                                            <% } else if (neg.estadoTraspaso === 'negociando') { %>
                                                <button onclick="negociarTraspasoClub(
                                                    '<%= neg.objetivoId._id %>', 
                                                    '<%= neg.ofertaTraspaso || 0 %>', 
                                                    '<%= neg.contraofertaTraspaso || 0 %>', 
                                                    '<%= neg.tipoOferta %>',
                                                    '<%= neg.porcentajeFuturaVenta || 0 %>',
                                                    '<%= neg.precioRecompra || 0 %>',
                                                    '<%= neg.clausulaCompra || 0 %>'
                                                    )" 
                                                        class="btn btn-sm btn-primary">
                                                    Mejorar Oferta
                                                </button>
                                                <button onclick="finalizarNegociacion('<%= neg._id %>')" class="btn btn-sm btn-outline-danger">
                                                    finalizar
                                                </button>

                                            <% } else if (neg.estadoTraspaso === 'rechazado') { %>
                                                <button onclick="borrarNegociacion('<%= neg._id %>')" class="btn btn-sm btn-outline-secondary">
                                                     <i class="bi bi-trash"></i>
                                                </button>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>

        <div class="tab-pane fade" id="recibidas" role="tabpanel">
            <% if (ofertasRecibidas.length === 0) { %>
                <div class="text-center p-5 bg-light rounded border">
                    <i class="bi bi-mailbox fs-1 text-muted"></i>
                    <p class="text-muted mt-2">No has recibido ninguna oferta por tus jugadores.</p>
                </div>
            <% } else { %>
                <div class="table-responsive bg-white shadow-sm rounded border">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Objetivo</th>
                                <th>Club Interesado</th>
                                <th>Estado</th>
                                <th class="text-center">Oferta Recibida</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% ofertasRecibidas.forEach(neg => { %>
                                <tr>
                                    <td>
                                        <% if (neg.objetivoId) { %>
                                            <div class="fw-bold"><%= neg.objetivoId.nombre %></div>
                                            <small class="text-muted">
                                                <%= neg.objetivoId.posicion %> • Valor: <%= (neg.objetivoId.valorMercado || 0).toLocaleString() %> € • Media <%= neg.objetivoId.valoracion %> • Posicion Principal <%= neg.objetivoId.posicionPrincipal %>
                                            </small>
                                        <% } else { %>
                                            <span class="text-danger">Jugador no encontrado</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <% if (neg.clubEmisor && neg.clubEmisor.escudo) { %>
                                                <img src="/img/escudos/<%= neg.clubEmisor.escudo %>" width="25" class="me-2">
                                            <% } %>
                                            <span><%= neg.clubEmisor ? neg.clubEmisor.nombre : 'Club Desconocido' %></span>
                                        </div>
                                    </td>
                                    <td>
                                        <% 
                                            let badgeColor = 'bg-warning text-dark';
                                            let estadoStr = neg.estadoTraspaso || 'pendiente';
                                            if (estadoStr === 'aceptado') badgeColor = 'bg-success';
                                            if (estadoStr === 'rechazado') badgeColor = 'bg-danger';
                                        %>
                                        <span class="badge <%= badgeColor %>">
                                            <%= estadoStr.toUpperCase() %>
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <div class="fw-bold text-primary fs-5">
                                            <%= (neg.ofertaTraspaso || 0).toLocaleString() %> €
                                        </div>
                                        <% if (neg.contraofertaTraspaso > 0 && neg.estadoTraspaso === 'negociando') { %>
                                            <small class="text-muted text-decoration-line-through">
                                                Original: <%= (neg.ofertaTraspaso || 0).toLocaleString() %> €
                                            </small>
                                            <div class="text-info small">Tu contraoferta: <%= (neg.contraofertaTraspaso || 0).toLocaleString() %> €</div>
                                        <% } %>
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex gap-2 justify-content-center">
                                            <% if (neg.estadoTraspaso === 'pendiente' || neg.estadoTraspaso === 'negociando') { %>
                                                <button onclick="responderOferta('<%= neg._id %>', 'aceptar')" class="btn btn-sm btn-success">
                                                    <i class="bi bi-check-lg"></i> Aceptar
                                                </button>

                                                <button onclick="negociarTraspasoClub(
                                                    '<%= neg.objetivoId._id %>',
                                                    '<%= neg.ofertaTraspaso || 0 %>', 
                                                    '<%= neg.contraofertaTraspaso || 0 %>', 
                                                    '<%= neg.tipoOferta %>',
                                                    '<%= neg.porcentajeFuturaVenta || 0 %>',
                                                    '<%= neg.precioRecompra || 0 %>',
                                                    '<%= neg.clausulaCompra || 0 %>'
                                                )" class="btn btn-sm btn-primary">
                                                    Contraofertar
                                                </button>

                                                <button onclick="responderOferta('<%= neg._id %>', 'rechazar')" class="btn btn-sm btn-danger">
                                                    <i class="bi bi-x-lg"></i>
                                                </button>
                                            <% } else { %>
                                                <button onclick="borrarNegociacion('<%= neg._id %>')" class="btn btn-sm btn-outline-secondary">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>
</div>
<%- include('partials/modal_traspasos') %>
<%- include('partials/modal_contratos') %>
<script src="/js/plantilla.js"></script>