<%- include('partials/head', {title: 'Gestión de Cantera'}) %>
<%- include('partials/navbar') %>

<div class="container-fluid mt-3">
    <ul class="nav nav-pills mb-3 justify-content-center" id="canteraMainTabs" role="tablist">
        <li class="nav-item">
            <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#seccion-filial">
                <i class="bi bi-people-fill me-2"></i>Jugadores del Filial
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#seccion-ojeadores">
                <i class="bi bi-search-heart me-2"></i>Red de Ojeadores
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab-pane fade show active" id="seccion-filial">
            <div class="row">
                <div class="col-md-7 border-end" style="height: 75vh; overflow-y: auto;">
                    <h4 class="mb-3 text-primary">Equipo filial: <%= clubUsuario.nombre %>
                    <img src="/img/escudos/<%= clubUsuario.escudo %>"
                            alt="<%= clubUsuario.escudo %>" 
                            class="ms-1 shadow-sm" 
                            style="height: 50px; width: auto; vertical-align: middle; border-radius: 2px;"
                        > 
                    </h4>
                    <table class="table table-dark table-hover align-middle shadow-sm border">
                        <thead class="table-dark border">
                            <tr class="small text-uppercase">
                                <th>Jugador</th>
                                <th>Posición</th>
                                <th>Edad</th>
                                <th>Media</th>
                                <th>Potencial</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% jugadoresFilial.forEach(j => { %>
                                <tr style="cursor: pointer;" onclick="verDetalleJugador('<%= j._id %>')">
                                    <td class="fw-bold"><%= j.nombre %></td>
                                    <td><span class="badge bg-secondary"><%= j.posicionPrincipal %></span></td>
                                    <td><%= j.edad %> años</td>
                                    <td><%= j.valoracion %></td>
                                    <td><%= j.potencial %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
                <div class="col-md-5 bg-light border rounded" id="panelDetalleJugador">
                    <div class="text-center mt-5 text-muted">
                        <i class="bi bi-person-badge display-1"></i>
                        <p>Selecciona una promesa para gestionar su futuro</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="seccion-ojeadores">
            <div class="row row-cols-1 row-cols-md-3 g-4">
                <% ojeadores.forEach(ojeador => { %>
                    <%- include('partials/redOjeadores', { ojeador: ojeador, contexto: 'cantera' }) %>
                <% }) %>
            </div>
        </div>
    </div>
</div>

<script src="/js/plantilla.js"></script>
<script src="/js/vistaAlertas.js"></script>
